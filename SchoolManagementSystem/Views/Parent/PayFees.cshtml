@model IEnumerable<SchoolManagementSystem.Models.FeePaymentViewModel>
@{
    ViewBag.Title = "Pay Fees";
}
<h2 class="mb-4 mt-3 fw-bold profile" style="color: #2d5f5d;">
    <i class="bi bi-credit-card-fill me-2"></i> Pay Fees
</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>No.</th>
                <th>Class</th>
                <th>Fee Type</th>
                <th>Amount (₹)</th>
                <th>Status</th>
                <th>Payment Date</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @{ int i = 1;}

            @foreach (var item in Model)
            {
                <tr>
                    <td>@i</td>
                    <td>@item.ClassName</td>
                    <td>@item.FeeType</td>
                    <td>@item.Amount.ToString("N2")</td>
                    <td>
                        @if (item.Status == "Pending")
                        {
                            <span class="badge bg-danger">Pending</span>
                        }
                        else if (item.Status == "Paid")
                        {
                            <span class="badge bg-success">Paid</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">@item.Status</span>
                        }
                    </td>
                    <td>
                        @(item.PaymentDate.HasValue ? item.PaymentDate.Value.ToString("dd MMM yyyy") : "-")
                    </td>
                    <td>
                        @if (item.Status == "Pending")
                        {
                            using (Html.BeginForm("InitiatePayment", "Parent", FormMethod.Post))
                            {
                                @Html.Hidden("id", item.PaymentId)
                                <button type="submit" class="btn btn-success btn-sm">Pay Fees</button>
                            }
                        }
                        else if (item.Status == "Paid")
                        {
                            <button class="btn btn-secondary btn-sm" disabled>Already Paid</button>
                            if (!string.IsNullOrEmpty(item.ReceiptPath))
                            {
                                @Html.ActionLink("📥 Download Receipt", "DownloadReceipt", new { id = item.PaymentId }, new { @class = "btn btn-success btn-sm ms-2" })
                            }
                        }
                        else
                        {
                            <button class="btn btn-warning btn-sm" disabled>Failed</button>
                        }
                    </td>
                </tr>
                i++;
            }
        </tbody>
    </table>
</div>

<style>
    .profile-wrapper {
        margin: 30px;
        padding: 25px;
    }

    .profile {
        margin: 10px 30px;
    }
</style>