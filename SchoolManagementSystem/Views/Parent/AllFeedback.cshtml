@model IEnumerable<SchoolManagementSystem.Models.Feedback>

@{
    ViewBag.Title = "All Parents Feedback";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-4 mt-3 text-primary fw-bold profile">
    <h2 style="color: #2d5f5d;"><i class="bi bi-people-fill"></i> Parents Feedback Wall</h2>
</div>

<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <table class="table table-bordered table-striped table-hover" style="table-layout: fixed; word-wrap: break-word;">


        <thead class="table-dark">
            <tr>
                <th style="width:5%">No.</th>
                <th style="width:15%">Parent Name</th>
                <th style="width:30%">Feedback</th>
                <th style="width:30%">Reply</th>
                <th style="width:20%">Date</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                int i = 1;

                foreach (var f in Model)
                {
                    <tr>
                        <td>@i</td>

                        <!-- Parent Name -->
                        <td>
                            @(f.Parent != null
        ? f.Parent.ParentFirstName + " " + f.Parent.ParentLastName
        : "Parent")
                        </td>

                        <td>@f.Message</td>

                        <td>
                            @(string.IsNullOrEmpty(f.Reply)
                                ? "⏳ Pending"
                                : f.Reply)
                        </td>

                        <td>@f.CreatedAt.ToString("dd-MMM-yyyy")</td>
                    </tr>

                    i++;
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">
                        No feedback available
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>
<style>
    .profile-wrapper {
        margin: 30px; /* outside space */
        padding: 25px; /* inside space */
    }

    .profile {
        margin: 10px 30px;
        /*        padding: 15px;  inside space */
    }

    .profile1 {
        margin: 10px 30px;
        margin-left: 100px;
    }

    .required-star {
        color: red;
        font-weight: bold;
        margin-left: 4px;
    }
    .table td, .table th {
        word-break: break-word;
        white-space: normal;
        vertical-align: middle;
    }
</style>