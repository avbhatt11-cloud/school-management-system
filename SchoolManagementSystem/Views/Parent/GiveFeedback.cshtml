@model SchoolManagementSystem.Models.Feedback

@{
    ViewBag.Title = "Give Feedback";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Parent Layout
}

<div class="mb-4 mt-3 text-primary fw-bold profile">
    <h2 style="color: #2d5f5d;"><i class="bi bi-chat-left-dots-fill"></i> Give Feedback</h2>
</div>


<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    @using (Html.BeginForm("GiveFeedback", "Parent", FormMethod.Post, new { id = "feedbackForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="mb-3">
            @Html.LabelFor(m => m.Message, new { @class = "form-label fw-bold" })
            <span class="required-star">*</span>

            @Html.TextAreaFor(m => m.Message, new
       {
           @class = "form-control",
           rows = 4,
           placeholder = "Write your feedback here...",
           required = "required",
           maxlength = "200",

       })

            @Html.ValidationMessageFor(m => m.Message, "", new { @class = "text-danger" })
        </div>


        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-send me-1"></i> Submit Feedback
            </button>
            <button type="button" class="btn btn-secondary px-4" onclick="resetForm()">
                <i class="bi bi-x-circle me-1"></i> Cancel
            </button>
        </div>
    }
</div>

<style>
    .profile-wrapper {
        margin: 30px; /* outside space */
        padding: 25px; /* inside space */
    }

    .profile {
        margin: 10px 30px;
        /*        padding: 15px;  inside space */
    }

    .profile1 {
        margin: 10px 30px;
        margin-left: 100px;
    }

    .required-star {
        color: red;
        font-weight: bold;
        margin-left: 4px;
    }
</style>
<script>
    function resetForm() {
        document.getElementById('feedbackForm').reset();
        $('.text-danger').text(''); // Validation errors clear karo
    }
</script>