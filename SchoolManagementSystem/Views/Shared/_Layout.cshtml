@{
    string role = Session["Role"] != null ? Session["Role"].ToString() : "";
    string username = Session["Username"] != null ? Session["Username"].ToString() : "Guest";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - School Management System</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="~/Content/site.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2d5f5d;
            --coral: #ff6b6b;
            --navbar-height: 56px;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        html, body {
            width: 100%;
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden !important;
        }

        /* ===== NAVBAR ===== */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1050;
            box-shadow: 0 2px 8px rgba(0,0,0,.2);
            background: linear-gradient(135deg, #2d5f5d 0%, #1e4644 100%) !important;
            padding: 0 1rem !important;
            min-height: var(--navbar-height);
        }

        .navbar-brand {
            font-size: 1.4rem;
            font-weight: 700;
            padding: 8px 0 !important;
            margin: 0 !important;
        }

            .navbar-brand span {
                color: #ff6b6b !important;
            }

        .navbar-logo {
            height: 40px;
            width: auto;
            object-fit: contain;
        }

        .nav-link {
            font-weight: 500;
            color: white !important;
            transition: all 0.3s;
            position: relative;
            padding: 8px 12px !important;
            white-space: nowrap;
        }

            .nav-link:hover {
                color: white !important;
                transform: translateY(-1px);
            }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: 2px;
                left: 50%;
                width: 0;
                height: 2px;
                background: #ff6b6b;
                transition: all 0.3s;
                transform: translateX(-50%);
            }

            .nav-link:hover::after {
                width: 75%;
            }

            /* Override Bootstrap's default ::after for dropdown toggles */
            .nav-link.dropdown-toggle::after {
                position: static;
                transform: none;
                background: none;
                height: auto;
                width: auto;
                border-top: 0.3em solid;
                border-right: 0.3em solid transparent;
                border-left: 0.3em solid transparent;
                display: inline-block;
                vertical-align: middle;
                margin-left: 4px;
            }

            .nav-link.dropdown-toggle:hover::after {
                width: auto;
                background: none;
            }

        .dropdown-menu {
            border: none;
            border-top: 3px solid #ff6b6b;
            box-shadow: 0 6px 20px rgba(0,0,0,.15);
            border-radius: 10px;
            margin-top: 8px;
        }

        .dropdown-item {
            padding: 10px 20px;
            transition: all 0.2s;
            color: #333;
        }

            .dropdown-item:hover {
                background: #f0faf9;
                color: #2d5f5d;
                transform: translateX(4px);
                border-left: 3px solid #ff6b6b;
            }

        .btn-nav-login {
            display: inline-block;
            border: 2px solid #ff6b6b;
            border-radius: 25px;
            padding: 6px 22px;
            font-weight: 700;
            font-size: 0.95rem;
            transition: all 0.3s;
            text-decoration: none;
            background: #ff6b6b;
            color: white !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 14px rgba(255,107,107,0.45);
        }

        .logout-link {
            color: #ff6b6b !important;
            font-weight: 700;
        }

            .logout-link:hover {
                color: #e05555 !important;
            }

            .logout-link::after {
                background: #ff6b6b !important;
            }

        .user-badge {
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
        }

        body {
            padding-top: 0 !important;
        }

        main {
            padding-top: var(--navbar-height);
        }

        .btn-primary {
            background: linear-gradient(135deg, #2d5f5d 0%, #1e4644 100%);
            border: none;
            transition: all 0.3s;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(45,95,93,0.4);
            }

        /* ===== FOOTER ===== */
        footer {
            background: linear-gradient(135deg, #2d5f5d 0%, #1e4644 100%);
            margin-top: auto;
            padding: 40px 0 20px;
            width: 100%;
        }

        .container-footer {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 30px;
        }

        .footer-left {
            flex: 1;
        }

            .footer-left h5 {
                font-size: 1.5rem;
                font-weight: bold;
                margin-bottom: 10px;
                color: #ff6b6b;
            }

            .footer-left p {
                font-size: 0.9rem;
                opacity: 0.9;
                margin: 0;
                color: white;
            }

        .footer-right {
            text-align: center;
        }

            .footer-right h6 {
                font-size: 1.1rem;
                font-weight: bold;
                margin-bottom: 15px;
                color: #ff6b6b;
            }

            .footer-right ul {
                list-style: none;
                padding: 0;
                margin: 0;
            }

                .footer-right ul li {
                    margin-bottom: 8px;
                }

                    .footer-right ul li a {
                        color: rgba(255,255,255,0.8);
                        text-decoration: none;
                        font-size: 0.9rem;
                        transition: color 0.3s;
                    }

                        .footer-right ul li a:hover {
                            color: #ff6b6b;
                            text-decoration: underline;
                        }

        .footer-bottom {
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.2);
            font-size: 0.85rem;
            opacity: 0.8;
            color: white;
        }

        @@media (max-width: 991px) {
            .navbar-collapse {
                background: rgba(30,70,68,0.97);
                padding: 20px;
                border-radius: 10px;
                margin-top: 10px;
                border-top: 2px solid #ff6b6b;
            }

            .nav-link::after {
                display: none;
            }
        }

        @@media (max-width: 768px) {
            .footer-content {
                flex-direction: column;
                gap: 30px;
                text-align: center;
            }

            .footer-left, .footer-right {
                text-align: center;
            }
        }


        @@media print {
            nav, footer, .navbar {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top no-print">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="@Url.Action("Index", "Home")">
                <img src="~/Content/images/lo.png" alt="Smart Eduverse Logo" class="navbar-logo me-1" style="width:-20px;" />
                <span>Smart Eduverse</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    @* -------- ADMIN MENU -------- *@
                    @if (role == "Admin")
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index","Admin")"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("ManageStaff","Admin")"><i class="bi bi-people me-1"></i> Manage Staff</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("ViewParents","Admin")"><i class="bi bi-person-hearts me-1"></i> View Parents</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("ManageGallery","Admin")"><i class="bi bi-images me-1"></i> Gallery</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("ManageFees","Admin")"><i class="bi bi-currency-rupee me-1"></i> Fees</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("ManageNotification","Admin")"><i class="bi bi-bell me-1"></i> Notifications</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("ManageFeedback","Admin")"><i class="bi bi-chat-dots me-1"></i> Feedback</a></li>
                    }

                    @* -------- STAFF MENU (CLEAN - 5 items only) -------- *@
                    else if (role == "Staff")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index","Staff")">
                                <i class="bi bi-speedometer2 me-1"></i> Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ManageProfile","Staff")">
                                <i class="bi bi-person-circle me-1"></i> My Profile
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ManageParents","Staff")">
                                <i class="bi bi-people me-1"></i> Parents
                            </a>
                        </li>

                        <!-- Academics Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-book me-1"></i> Academics
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="@Url.Action("ManageStudentsAttendance","Staff")"><i class="bi bi-calendar-check me-2"></i> Manage Attendance</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("ManageTimeTable","Staff")"><i class="bi bi-table me-2"></i> Time Table</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("UploadMaterial","Staff")"><i class="bi bi-cloud-upload me-2"></i> Upload Material</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("ViewLeaveReport","Staff")"><i class="bi bi-file-text me-2"></i> Leave Reports</a></li>
                            </ul>
                        </li>

                        <!-- Exams Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-clipboard-data me-1"></i> Exams
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="@Url.Action("PostExamSchedule","Staff")"><i class="bi bi-calendar-event me-2"></i> Post Schedule</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("PostResult","Staff")"><i class="bi bi-award me-2"></i> Post Results</a></li>
                            </ul>
                        </li>

                        <!-- More Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-grid me-1"></i> More
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="@Url.Action("ManageFAQs","Staff")"><i class="bi bi-question-circle me-2"></i> Manage FAQs</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("ViewNotification","Staff")"><i class="bi bi-bell me-2"></i> Notifications</a></li>
                            </ul>
                        </li>
                    }

                    @* -------- PARENT MENU -------- *@
                    else if (role == "Parent")
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index","Parent")"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("ManageProfile","Parent")"><i class="bi bi-person-circle me-1"></i> My Profile</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Parent/ViewGallery"><i class="bi bi-images me-1"></i> Gallery</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("PayFees","Parent")"><i class="bi bi-credit-card me-1"></i> Pay Fees</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"><i class="bi bi-book me-1"></i> Academics</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="@Url.Action("ViewAttendance","Parent")"><i class="bi bi-calendar-check me-2"></i> View Attendance</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("ViewTimeTable","Parent")"><i class="bi bi-table me-2"></i> Time-table</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("ViewMaterial","Parent")"><i class="bi bi-file-earmark-text me-2"></i> Study Material</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("ViewExamSchedule","Parent")"><i class="bi bi-calendar-event me-2"></i> Exam Schedule</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("GiveLeaveReport","Parent")"><i class="bi bi-file-text me-2"></i> Leave Report</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("ViewResult","Parent")"><i class="bi bi-award me-2"></i> View Results</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("GetNotification","Parent")"><i class="bi bi-bell me-2"></i> Notifications</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"><i class="bi bi-chat-square-text me-1"></i> Feedback</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="@Url.Action("ViewFeedback","Parent")"><i class="bi bi-eye me-2"></i> View Feedback</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("GiveFeedback","Parent")"><i class="bi bi-pencil-square me-2"></i> Give Feedback</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("AllFeedback","Parent")"><i class="bi bi-people-fill me-2"></i> All Parents Feedback</a></li>
                            </ul>
                        </li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("AskFAQs","Parent")"><i class="bi bi-question-circle me-1"></i> FAQ's</a></li>
                    }

                    @* -------- VISITOR MENU -------- *@
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index","Home")"><i class="bi bi-house-door me-1"></i> Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("About","Home")"><i class="bi bi-info-circle me-1"></i> About Us</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("OurStaff","Home")"><i class="bi bi-person-workspace me-2"></i>Our Staff </a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Gallery","Home")"><i class="bi bi-images me-1"></i> Gallery</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("AskFAQ","Home")"><i class="bi bi-question-circle me-1"></i> FAQ's</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Contact","Home")"><i class="bi bi-envelope me-1"></i> Contact</a></li>

                    }
                </ul>

                <ul class="navbar-nav align-items-center gap-2">
                    @if (!string.IsNullOrEmpty(role))
                    {
                        <li class="nav-item d-flex align-items-center">
                            <span class="user-badge text-white">
                                <i class="bi bi-person-circle me-1"></i>
                                <strong>@username</strong> <small>(@role)</small>
                            </span>
                        </li>
                        <li class="nav-item">
                            @if (role == "Admin")
                            {
                                <a class="btn-nav-login" href="@Url.Action("Logout","AdminAccount")">
                                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                                </a>
                            }
                            else
                            {
                                <a class="btn-nav-login" href="@Url.Action("Logout","Account")">
                                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                                </a>
                            }
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn-nav-login" href="@Url.Action("Login","Account")">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="text-light no-print">
        <div class="container-footer">
            <div class="footer-content">
                <div class="footer-left">
                    <h5>Smart Eduverse</h5>
                    <p>Empowering education through technology</p>
                </div>
                <div class="footer-right">
                    <h6>Quick Links</h6>
                    <ul>
                        <li><a href="@Url.Action("About","Home")">About Us</a></li>
                        <li><a href="@Url.Action("Contact","Home")">Contact</a></li>
                        <li><a href="@Url.Action("AskFAQ","Home")">FAQ</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p class="mb-0">&copy; @DateTime.Now.Year School Management System. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>


    @RenderSection("Scripts", required: false)
    <script src="~/Scripts/jquery-3.6.0.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>