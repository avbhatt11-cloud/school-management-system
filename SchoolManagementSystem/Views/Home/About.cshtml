@{
    ViewBag.Title = "About Us";
}

<!-- Page Header -->
<div class="bg-light">
    <div class="page-header text-green py-5 mb-5 mt-0">
        <div class="container-fluid custom-padding">
            <h1 class="display-4 fw-bold">About Our SmartEduverse</h1>
            <p class="lead mb-0">Building futures through quality education</p>
        </div>
    </div>

    <!-- Mission & Vision -->

    <section class="container-fluid custom-padding mb-5 ">
        <div class="row g-4 ">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100 vision-card">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-circle-coral me-3">
                                <i class="bi bi-bullseye"></i>
                            </div>
                            <h3 class="fw-bold mb-0">Our Mission</h3>
                        </div>
                        <p class="text-muted mb-0">To provide quality education that empowers students with knowledge, skills, and values to become responsible global citizens. We strive to create a nurturing environment where every student can discover their potential and achieve excellence in academics, character, and service.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100 vision-card">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-circle-coral me-3">
                                <i class="bi bi-eye-fill"></i>
                            </div>
                            <h3 class="fw-bold mb-0">Our Vision</h3>
                        </div>
                        <p class="text-muted mb-0">To be a leading educational institution recognized for academic excellence, innovative teaching methods, and holistic development of students. We envision a future where our graduates are confident, compassionate leaders who contribute positively to society and make a meaningful difference in the world.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Values -->
    <section class="bg-light py-5 mb-5">
        <div class="container-fluid custom-padding">
            <div class="text-center mb-5">
                <h2 class="display-6 fw-bold mb-3">Our Core Values</h2>
                <p class="lead text-muted">The principles that guide everything we do</p>
            </div>
            <div class="row g-4">

                <!-- Excellence → Blue (Bootstrap default primary) -->
                <div class="col-md-4">
                    <div class="text-center value-item">
                        <div class="value-icon-wrap" style="background: rgba(59,130,246,0.12);">
                            <i class="bi bi-trophy-fill" style="color: #3b82f6;"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Excellence</h5>
                        <p class="text-muted small">Commitment to the highest standards in education and character development</p>
                    </div>
                </div>

                <!-- Integrity → Green -->
                <div class="col-md-4">
                    <div class="text-center value-item">
                        <div class="value-icon-wrap" style="background: rgba(16,185,129,0.12);">
                            <i class="bi bi-shield-check" style="color: #10b981;"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Integrity</h5>
                        <p class="text-muted small">Upholding honesty, transparency, and ethical behavior in all interactions</p>
                    </div>
                </div>

                <!-- Innovation → Orange/Amber -->
                <div class="col-md-4">
                    <div class="text-center value-item">
                        <div class="value-icon-wrap" style="background: rgba(245,158,11,0.12);">
                            <i class="bi bi-lightbulb-fill" style="color: #f59e0b;"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Innovation</h5>
                        <p class="text-muted small">Embracing new ideas and technologies to enhance learning experiences</p>
                    </div>
                </div>

                <!-- Respect → Light Blue -->
                <div class="col-md-4">
                    <div class="text-center value-item">
                        <div class="value-icon-wrap" style="background: rgba(93,173,226,0.12);">
                            <i class="bi bi-heart-fill" style="color: #5dade2;"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Respect</h5>
                        <p class="text-muted small">Valuing diversity and treating everyone with dignity and compassion</p>
                    </div>
                </div>

                <!-- Responsibility → Coral Red -->
                <div class="col-md-4">
                    <div class="text-center value-item">
                        <div class="value-icon-wrap" style="background: rgba(255,107,107,0.12);">
                            <i class="bi bi-award-fill" style="color: #ff6b6b;"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Responsibility</h5>
                        <p class="text-muted small">Fostering accountability and ownership in students and staff</p>
                    </div>
                </div>

                <!-- Community → Purple -->
                <div class="col-md-4">
                    <div class="text-center value-item">
                        <div class="value-icon-wrap" style="background: rgba(139,92,246,0.12);">
                            <i class="bi bi-people-fill" style="color: #8b5cf6;"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Community</h5>
                        <p class="text-muted small">Building strong partnerships between school, families, and society</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section class="container-fluid  custom-paddingg mb-5 bg-light">
        <div class="container-fluid">
            <div class="text-center mb-5">
                <h2 class="display-6 fw-bold mb-3">Why Choose Us</h2>
                <p class="lead text-muted">What makes us stand out from the rest</p>
            </div>
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="d-flex why-item">
                        <div class="flex-shrink-0">
                            <div class="num-circle">1</div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="fw-bold mb-2">Experienced Faculty</h5>
                            <p class="text-muted mb-0">Our teachers are highly qualified professionals dedicated to student success with years of teaching experience.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="d-flex why-item">
                        <div class="flex-shrink-0">
                            <div class="num-circle">2</div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="fw-bold mb-2">Modern Infrastructure</h5>
                            <p class="text-muted mb-0">State-of-the-art facilities including smart classrooms, laboratories, library, and sports amenities.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="d-flex why-item">
                        <div class="flex-shrink-0">
                            <div class="num-circle">3</div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="fw-bold mb-2">Holistic Development</h5>
                            <p class="text-muted mb-0">We focus on academic excellence alongside sports, arts, and extracurricular activities.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="d-flex why-item">
                        <div class="flex-shrink-0">
                            <div class="num-circle">4</div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="fw-bold mb-2">Technology Integration</h5>
                            <p class="text-muted mb-0">Digital learning platforms and management systems keep parents connected with their child's progress.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="d-flex why-item">
                        <div class="flex-shrink-0">
                            <div class="num-circle">5</div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="fw-bold mb-2">Safe Environment</h5>
                            <p class="text-muted mb-0">A secure campus with CCTV surveillance and trained staff ensures student safety at all times.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="d-flex why-item">
                        <div class="flex-shrink-0">
                            <div class="num-circle">6</div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="fw-bold mb-2">Parent Partnership</h5>
                            <p class="text-muted mb-0">Regular communication and involvement of parents in their child's educational journey.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA - NO green bg, simple light bg -->
    <section class="cta-section py-5">
        <div class="container text-center py-4">
            <h2 class="display-6 fw-bold mb-3">Join Our Community Today</h2>
            <p class="lead mb-4 text-muted">Be part of an institution committed to excellence in education</p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="@Url.Action("Contact","Home")" class="btn btn-cta-outline btn-lg px-5">Contact Us</a>
                <a href="@Url.Action("Login","Account")" class="btn btn-cta-coral btn-lg px-5">Login</a>
            </div>
        </div>
    </section>
</div>
<style>
    html, body {
        width: 100%;
        margin: 0 !important;
        padding: 0 !important;
        overflow-x: hidden !important;
    }

    .custom-padding {
        padding-left: 66px;
        padding-right: 66px;
    }

    .custom-paddingg {
        padding-left: 60px;
        padding-right: 50px;
    }


    /* ===== PAGE HEADER ===== */
    .page-header {
        background: #B2D3C2;
        margin-top: 56px;
    }

    /* ===== MISSION / VISION CARDS ===== */
    .mission-card {
        border-top: 4px solid #2d5f5d !important;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .vision-card {
        border-top: 4px solid #ff6b6b !important;
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .mission-card:hover, .vision-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 2rem rgba(0,0,0,.12) !important;
        }

    .icon-circle-teal {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(45,95,93,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        color: #2d5f5d;
        flex-shrink: 0;
    }

    .icon-circle-coral {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255,107,107,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        color: #ff6b6b;
        flex-shrink: 0;
    }

    /* ===== CORE VALUES ===== */
    .value-icon-wrap {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
        font-size: 38px;
    }

    /* ===== WHY CHOOSE US - Coral Red numbers, NO animation ===== */
    .num-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #ff6b6b; /* Coral Red only */
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.1rem;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(255,107,107,0.3);
    }

    .why-item {
        padding: 12px;
        border-radius: 12px;
    }

    /* ===== CTA - Plain light background ===== */
    .cta-section {
        background: #f8f9fa; /* Simple light bg - no green */
    }

    /* Contact Us → teal outline */
    .btn-cta-outline {
        background: transparent;
        color: #2d5f5d;
        border: 2px solid #2d5f5d;
        font-weight: 600;
        transition: all 0.3s;
        border-radius: 8px;
    }

        .btn-cta-outline:hover {
            background: #e05555;
            border-color: #e05555;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255,107,107,0.4);
        }


    /* Login → coral red solid */
    .btn-cta-coral {
        background: #ff6b6b;
        color: white;
        border: 2px solid #ff6b6b;
        font-weight: 600;
        transition: all 0.3s;
        border-radius: 8px;
    }

        .btn-cta-coral:hover {
            background: #e05555;
            border-color: #e05555;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255,107,107,0.4);
        }

    .text-green {
        color: #2d5f5d !important;
    }
</style>
