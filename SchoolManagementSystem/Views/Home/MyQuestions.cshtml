@model IEnumerable<SchoolManagementSystem.Models.FAQ>

@{
    ViewBag.Title = "My Questions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">


<div class="mt-3 mb-4 mt-2 fw-bold profile">

    <h2 class=" text-green">
        <i class="fas fa-headset"></i>
        Questions & Answers
    </h2>
</div>

<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <!-- Email Search Form -->
    @using (Html.BeginForm())
    {
        <div class="row mb-4">
            <div class="col-md-6">
                <input type="email"
                       name="email"
                       class="form-control"
                       placeholder="Enter your email"
                       required />
            </div>

            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search me-1"></i> Search
                </button>

                <a href="@Url.Action("AskFAQ","Home")" class="btn btn-secondary">
                    <i class="fas me-1"></i> Back to list
                </a>
            </div>

        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="accordion" id="myFaqs">

            @foreach (var item in Model)
            {
                <div class="accordion-item mb-3 shadow-sm">

                    <h2 class="accordion-header">

                        <button class="accordion-button collapsed"
                                data-bs-toggle="collapse"
                                data-bs-target="#faq_@item.FAQId">

                            ❓ @item.Question

                        </button>

                    </h2>

                    <div id="faq_@item.FAQId"
                         class="accordion-collapse collapse">

                        <div class="accordion-body">

                            <p>
                                <strong>Asked On:</strong>
                                @item.AskedOn.ToString("dd-MM-yyyy")
                            </p>

                            <hr />

                            @if (!string.IsNullOrEmpty(item.Answer))
                            {
                                <p class="text-success">
                                    <strong>✅ Answer:</strong><br />
                                    @item.Answer
                                </p>
                            }
                            else
                            {
                                <p class="text-warning">
                                    ⏳ <strong>Pending:</strong>
                                    Staff has not replied yet.
                                </p>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>
    }
    else if (Model != null)
    {
        <div class="alert alert-warning">
            ❌ No questions found for this email.
        </div>
    }

</div>

<style>
    .profile-wrapper {
        margin: 30px;
        padding: 25px;
    }

    .profile {
        margin: 10px 30px;
    }

    .text-danger {
        font-size: 0.875rem;
    }

    .text-green {
        color: #2d5f5d !important;
    }

    .btn-secondary:hover,
    .btn-secondary:focus,
    .btn-secondary:active {
        background-color: #6c757d !important;
        border-color: #6c757d !important;
        box-shadow: none !important;
    }

    /* ✅ FIX: Long question text overflow */
    .accordion-button {
        word-break: break-word;
        white-space: normal;
        overflow-wrap: break-word;
    }

    .accordion-item {
        overflow: hidden;
    }

    .accordion-body p {
        word-break: break-word;
        overflow-wrap: break-word;
    }
</style>