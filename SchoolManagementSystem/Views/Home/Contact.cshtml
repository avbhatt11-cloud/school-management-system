@{
    ViewBag.Title = "Contact Us";
}

<!-- Page Header -->
<div class="bg-light">
    <div class="contact-header text-green py-5 mb-5 mt-0">
        <div class="container-fluid custom-padding">
            <h1 class="display-4 fw-bold">Contact Us</h1>
            <p class="lead mb-0">We'd love to hear from you</p>
        </div>
    </div>
    <div class="container mb-5">
        <!-- Contact Information -->
        <h2 class="fw-bold text-center mb-2 py-2">Get in Touch</h2>
        <p class="text-muted text-center">Have questions about admissions, programs, or anything else? Feel free to reach out to us through any of the following channels.</p>
    </div>

    <!-- Contact Cards -->
    <div class="container-fluid custom-padding py-2">
        <div class="row g-4">

            <!-- Address -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100 contact-card">
                    <div class="card-body p-4 d-flex">
                        <div class="contact-icon me-3">
                            <i class="bi bi-geo-alt-fill" style="color: #2d5f5d;"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-2">Address</h5>
                            <p class="text-muted mb-0">
                                Sayona Rd, near<br>
                                Redmond, Ahemdabad
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phone -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100 contact-card">
                    <div class="card-body p-4 d-flex">
                        <div class="contact-icon me-3" style="background: rgba(16,185,129,0.12);">
                            <i class="bi bi-telephone-fill" style="color: #10b981;"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-2">Phone</h5>
                            <p class="text-muted mb-1"><strong>+91</strong> 9982562341</p>
                            <p class="text-muted mb-0"><strong>+91</strong> 6228610101</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Email -->
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100 contact-card">
                    <div class="card-body p-4 d-flex">
                        <div class="contact-icon me-3" style="background: rgba(93,173,226,0.12);">
                            <i class="bi bi-envelope-fill" style="color: #5dade2;"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-2">Email</h5>
                            <p class="mb-1">
                                <strong>Admissions:</strong>
                                <a href="mailto:smarteduverse@gmail.com">smarteduverse@gmail.com</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Office Hours -->
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100 contact-card">
                    <div class="card-body p-4 d-flex">
                        <div class="contact-icon me-3" style="background: rgba(245,158,11,0.12);">
                            <i class="bi bi-clock-fill" style="color: #f59e0b;"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-2">Office Hours</h5>
                            <p class="text-muted mb-1">Mon – Fri: 8:00 AM – 5:00 PM</p>
                            <p class="text-muted mb-0">Saturday: 9:00 AM – 1:00 PM</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    /* ===== PAGE HEADER - Teal Green ===== */
    .contact-header {
        background: #B2D3C2;
        margin-top: 56px;
    }

    /* ===== CONTACT CARDS - no animation ===== */
    .contact-card {
        border-radius: 14px;
    }

    /* ===== CONTACT ICON CIRCLE ===== */
    .contact-icon {
        width: 52px;
        height: 52px;
        min-width: 52px;
        border-radius: 50%;
        background: rgba(45, 95, 93, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .contact-icon i {
            font-size: 20px;
        }

    /* ===== EMAIL LINK ===== */
    .contact-card a {
        color: #2d5f5d;
        text-decoration: none;
    }

        .contact-card a:hover {
            color: #ff6b6b;
            text-decoration: underline;
        }

    .text-green {
        color: #2d5f5d !important;
    }

    .custom-padding {
        padding-left: 66px;
        padding-right: 66px;
    }

    .custom-paddingg {
        padding-left: 60px;
        padding-right: 50px;
    }
</style>
