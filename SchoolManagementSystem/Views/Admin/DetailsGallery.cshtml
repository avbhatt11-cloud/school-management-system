@model SchoolManagementSystem.Models.Gallery
@{
    ViewBag.Title = "Photo Details";
}
<div class="container mt-4 text-primary fw-bold profile">

    <h2 class="text-green mt-2 mb-2">
        <i class="bi bi-image me-2 "></i> Photo Details
    </h2>
</div>
<div class="row mt-4 g-6 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <div>
        <h4>@Model.PhotoName</h4>
        <p>
            @if (!string.IsNullOrEmpty(Model.PhotoPath))
            {
                <img src="@Url.Content(Model.PhotoPath)"
                     alt="@Model.PhotoName"
                     width="300" />
            }
            else
            {
            <p class="text-danger">No Image Available</p>
        }
           
            <p><strong>Uploaded on:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy")</p>
        </div>

        <p>
            @Html.ActionLink("Back to list", "ManageGallery", null, new { @class = "btn btn-secondary" })
        </p>
    </div>
        <style>
            .profile-wrapper {
                margin: 30px;
                padding: 25px;
            }

            .profile {
                margin: 10px 30px;
            }

            .table-responsive {
                overflow-x: auto;
            }

            .badge {
                padding: 0.5em 0.75em;
                font-size: 0.875rem;
            }
            .text-green {
                color: #2d5f5d !important;
            }
        </style>
