@model IEnumerable<SchoolManagementSystem.Models.Parent>

@{
    ViewBag.Title = "View Parents";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mt-3 mb-4 mt-2 fw-bold profile">
    <h2 class=" text-green">
        <i class=" bi-person-heart me-2"></i> View Parent
    </h2>


</div>

<!-- Filters -->
<form method="get" class="row mb-3">
    <div class="col-md-4 profile">
        <select name="selectedClass" class="form-select" onchange="this.form.submit()">
            <option value="">-- Select Class --</option>
            @foreach (var cls in ViewBag.ClassList as List<string>)
            {
                <option value="@cls" @(cls == ViewBag.SelectedClass ? "selected" : "")>@cls</option>
            }
        </select>
    </div>

    <div class="col-md-4 profile">
        <select name="status" class="form-select" onchange="this.form.submit()">
            <option value="">-- All Parents --</option>
            <option value="Active" @(ViewBag.Status == "Active" ? "selected" : "")>Active Parents</option>
            <option value="Inactive" @(ViewBag.Status == "Inactive" ? "selected" : "")>Inactive Parents</option>
        </select>
    </div>

    <div class="col-md-2 profile1">
        <input type="text" id="parentSearch" class="form-control" placeholder="Search parents...">
    </div>
</form>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle" id="parentTable">
            <thead class="table-dark">
                <tr>
                    <th>No.</th>
                    <th>Parent Name</th>
                    <th>Email</th>
                    <th>Contact</th>
                    <th>Student Name</th>
                    <th>Class</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var parent in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td class="text-capitalize">@parent.ParentFirstName @parent.ParentLastName</td>
                            <td>@parent.Email</td>
                            <td>@parent.ContactNumber</td>
                            <td class="text-capitalize">
                                @parent.StudentFirstName @parent.StudentMiddleName @parent.StudentLastName
                            </td>
                            <td>@parent.ClassName</td>
                            <td>
                                @if (parent.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-3">No parents found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<!-- JavaScript for search -->
<script>
    document.getElementById("parentSearch").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        let rows = document.querySelectorAll("#parentTable tbody tr");
        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(value) ? "" : "none";
        });
    });
</script>


<style>
    .profile-wrapper {
        margin: 30px; /* outside space */
        padding: 25px; /* inside space */
    }

    .profile {
        margin: 10px 30px;
        /*        padding: 15px;  inside space */
    }
    .profile1 {
        margin: 10px 30px;
        margin-left: 100px;
    }
    .text-green {
        color: #2d5f5d !important;
    }
</style>
