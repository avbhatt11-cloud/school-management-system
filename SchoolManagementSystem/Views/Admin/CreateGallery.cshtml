@model SchoolManagementSystem.Models.Gallery
@{
    ViewBag.Title = "Add New Photo";
}
<div class="container mt-4 text-primary fw-bold profile">

    <h2 class="text-green mt-2 mb-2">
        <i class="bi bi-image me-2 "></i> Add New Photo
    </h2>
</div>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">



    @using (Html.BeginForm("CreateGallery", "Admin", FormMethod.Post,
            new { enctype = "multipart/form-data", novalidate = "novalidate" }))
    {
        @Html.AntiForgeryToken()

        <!-- Photo Name -->
        <div class="form-group mb-3">
            @Html.LabelFor(m => m.PhotoName)

            @Html.TextBoxFor(m => m.PhotoName,
                new { @class = "form-control" })

            @Html.ValidationMessageFor(m => m.PhotoName,
                "", new { @class = "text-danger" })
        </div>

        <!-- Upload Photo -->
        <div class="form-group mb-3">
            <label>Upload Photo</label>

            <input type="file" name="PhotoFile"
                   class="form-control"
                   accept=".jpg,.jpeg,.png,.gif"
                   required />


            @Html.ValidationMessage("PhotoFile",
                "", new { @class = "text-danger" })

            <small class="text-muted">Max size: 20MB</small>
        </div>

        <button type="submit" class="btn btn-success">Save</button>
        @Html.ActionLink("Cancel", "ManageGallery", null,
            new { @class = "btn btn-secondary" })
    }

</div>
<script>
    document.querySelector('input[type=file]').addEventListener('change', function () {

        if (this.files[0].size > 20971520) {
            alert("Max 20MB allowed");
            this.value = "";
        }

    });
</script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

<style>
    .profile-wrapper {
        margin: 30px;
        padding: 25px;
    }

    .profile {
        margin: 10px 30px;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .badge {
        padding: 0.5em 0.75em;
        font-size: 0.875rem;
    }
    .text-green {
        color: #2d5f5d !important;
    }
</style>
