@model IEnumerable<SchoolManagementSystem.Models.Notification>

@{
    ViewBag.Title = "Manage Notification";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Admin Layout
}



<!-- NAYA -->
<div class="d-flex justify-content-between align-items-center mb-4 profile">
    <h2 class=" text-green mt-2 mb-1">
        <i class="bi bi-bell me-2"></i>Manage Notifications
    </h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="row g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <!-- Add Notification Form -->
    @using (Html.BeginForm("CreateNotification", "Admin", FormMethod.Post,
       new { novalidate = "novalidate", id = "notificationForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="card shadow-sm p-4 mb-4">
            <div class="form-group mb-3">
                <label for="Role" class="fw-bold">Select Role</label>
                @Html.DropDownList("Role", new SelectList(new[] { "Staff", "Parent" }),
                    "-- Select Role --",
                    new { @class = "form-control" })

                @Html.ValidationMessage("Role", "", new { @class = "text-danger" })

            </div>

            <div class="form-group mb-3">
                <label for="Message" class="fw-bold">Message</label>
                @Html.TextArea("Message", null,
new { @class = "form-control", rows = 3 })

                @Html.ValidationMessage("Message", "", new { @class = "text-danger" })

            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send"></i> Send Notification
                </button>
                <button type="button" class="btn btn-secondary" onclick="resetNotificationForm()">
                    <i class="bi bi-x-circle"></i> Cancel
                </button>
            </div>
        </div>
    }

    <!-- Notification Table -->
    <div class="card shadow-sm p-4">
        <h4 class="mb-3">📋 Existing Notifications</h4>
        <table class="table table-bordered table-hover text-center" style="table-layout: fixed; word-wrap: break-word;">
            <thead style="background-color:#2f294c; color:white;">
                <tr>
                    <th style="width:5%">No.</th>
                    <th style="width:10%">Role</th>
                    <th style="width:45%">Message</th>
                    <th style="width:20%">Date Sent</th>
                    <th style="width:10%">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var notification in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@notification.Role</td>
                            <td style="word-break: break-word; white-space: normal; text-align: left;">@notification.Message</td>
                            <td>@notification.CreatedDate.ToString("dd-MMM-yyyy hh:mm tt")</td>
                            <td>
                                @Html.ActionLink(" Delete", "DeleteNotification", new { id = notification.Id },
                                    new { @class = "btn btn-danger btn-sm", onclick = "return confirm('Are you sure you want to delete this notification?');" })
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">No notifications found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
</div>

<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
<script>
    // Reset notification form function
    function resetNotificationForm() {
        var form = document.getElementById("notificationForm");

        // Form reset
        form.reset();

        // Validation messages clear karo
        var validationMessages = form.querySelectorAll('.text-danger');
        validationMessages.forEach(function (msg) {
            msg.innerHTML = "";
        });

        // Validation classes remove karo (if any)
        form.classList.remove('was-validated');
    }
</script>


<style>
    /* NAYA */
    .profile-wrapper {
        margin: 30px;
        padding: 25px;
    }

    .profile {
        margin: 10px 30px;
    }

    .profile1 {
        margin: 10px 30px;
        margin-left: 100px;
    }

    .text-green {
        color: #2d5f5d !important;
    }
</style>