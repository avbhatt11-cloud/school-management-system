@model SchoolManagementSystem.Models.Fee

@{
    ViewBag.Title = "Delete Fee";
}
<div class="d-flex justify-content-between align-items-center mb-4 profile">
    <h2 class="text-green mt-2 mb-2">

        <i class="bi bi-currency-rupee"></i>
        Delete Fee
    </h2>
</div>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <div class="alert alert-danger">
        Are you sure you want to delete this fee record?
    </div>

    <dl class="row">
        <dt class="col-sm-2">Class</dt>
        <dd class="col-sm-10">@Model.ClassName</dd>

        <dt class="col-sm-2">Amount</dt>
        <dd class="col-sm-10">@Model.Amount</dd>

        <dt class="col-sm-2">Created At</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="@Url.Action("ManageFees")" class="btn btn-secondary">Cancel</a>
    }
    </div>
    <style>
        .profile-wrapper {
            margin: 30px;
            padding: 25px;
        }

        .profile {
            margin: 10px 30px;
        }

        .table-responsive {
            overflow-x: auto;
        }

        .badge {
            padding: 0.5em 0.75em;
            font-size: 0.875rem;
        }
        .text-green {
            color: #2d5f5d !important;
        }
    </style>
