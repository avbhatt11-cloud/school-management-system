@model IEnumerable<SchoolManagementSystem.Models.Staff>
@{
    ViewBag.Title = "Manage Staff";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* Success Message Display *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mx-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>@TempData["Success"]</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* Error Message Display *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mx-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>@TempData["Error"]</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<!-- Replace the heading + buttons section -->
<div class="mt-3 mt-2 fw-bold profile d-flex align-items-center justify-content-between">
    <h2 class="text-green mb-4">
        <i class="bi bi-people me-2"></i> Manage Staff
    </h2>
    <div class="d-flex gap-2 me-2">
        <a class="btn btn-primary" href="@Url.Action("CreateStaff","Admin")">
            Add New Staff
        </a>
        @if (ViewBag.ShowInactive == true)
        {
            <a href="@Url.Action("ManageStaff", new { showInactive = false })"
               class="btn btn-danger text-decoration-none">
                Show Active
            </a>
        }
        else
        {
            <a href="@Url.Action("ManageStaff", new { showInactive = true })" class="btn btn-secondary text-decoration-none">Show Inactive</a>
        }
    </div>
</div>


<!-- Toggle Active/Inactive -->
<!-- Search box -->

<div class="mb-2 mt-2 me-4 profile">
    <input type="text" id="staffSearch" class="form-control" placeholder="Search staff...">
</div>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">
    <table class="table table-striped table-bordered" id="staffTable">
        <thead class="table-dark">
            <tr>
                <th>No.</th>
                <th>Photo</th>
                <th>Username</th>
                <th>Name</th>
                <th>Email</th>
                <th>Gender</th>
                <th>Contact</th>
                <th>Designation</th>
                <th>Class Assigned</th>
                <th>Status</th>
                <th style="width:220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                int i = 1;
                foreach (var item in Model)
                {
                    <tr class="@(item.IsActive ? "" : "table-warning")">
                        <td>@i</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.PhotoPath))
                            {
                                <img src="@Url.Content(item.PhotoPath)" style="width:60px;height:60px;object-fit:cover;border-radius:4px" />
                            }
                        </td>
                        <td>@item.Username</td>
                        <td>@item.FirstName @item.LastName</td>
                        <td>@item.Email</td>
                        <td>@item.Gender</td>
                        <td>@item.ContactNo</td>
                        <td>@item.Designation</td>
                        <td>@item.ClassAssigned</td>
                        <td>@(item.IsActive ? "Active" : "Inactive")</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-sm btn-outline-info no-hover-btn"
                                   href="@Url.Action("DetailsStaff","Admin", new { id = item.Id })">
                                    Details
                                </a>

                                <a class="btn btn-sm btn-outline-primary no-hover-btn"
                                   href="@Url.Action("EditStaff","Admin", new { id = item.Id })">
                                    Edit
                                </a>




                                @if (item.IsActive)
                                {
                                    <!-- Deactivate -->
                                    using (Html.BeginForm("DeleteStaff", "Admin", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.Id)

                                        <button type="submit"
                                                class="btn btn-sm btn-warning"
                                                onclick="return confirm('Deactivate this staff?')">
                                            Deactivate
                                        </button>
                                    }

                                    <!-- Permanent Delete -->
                                    using (Html.BeginForm("HardDeleteStaff", "Admin", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.Id)

                                        <button type="submit"
                                                class="btn btn-sm btn-danger"
                                                onclick="return confirm('This will permanently delete staff. Continue?')">
                                            Delete
                                        </button>
                                    }
                                }

                                else
                                {
                                    <!-- Restore -->
                                    using (Html.BeginForm("RestoreStaff", "Admin", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.Id)

                                        <button type="submit" class="btn btn-sm btn-success">
                                            Restore
                                        </button>
                                    }

                                    <!-- Permanent Delete -->
                                    using (Html.BeginForm("HardDeleteStaff", "Admin", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.Id)

                                        <button type="submit"
                                                class="btn btn-sm btn-danger"
                                                onclick="return confirm('Delete permanently?')">
                                            Delete
                                        </button>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                    i++;
                }
            }
        </tbody>
    </table>
</div>
<!-- JavaScript for search -->
<script>

    setTimeout(function () {
        $(".alert").fadeOut("slow");
    }, 5000);


    document.getElementById("staffSearch").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        let rows = document.querySelectorAll("#staffTable tbody tr");
        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(value) ? "" : "none";
        });
    });
</script>

<style>
    .profile-wrapper {
        margin: 30px; /* same as View Parent */
        padding: 25px; /* same inside spacing */
    }

    .profile {
        margin: 10px 30px; /* same as View Parent */
    }

    .text-green {
        color: #2d5f5d !important;
    }

    .no-hover-btn,
    .no-hover-btn:hover,
    .no-hover-btn:focus,
    .no-hover-btn:active {
        background-color: transparent !important;
        box-shadow: none !important;
    }

    .btn-outline-info.no-hover-btn,
    .btn-outline-info.no-hover-btn:hover {
        color: #0dcaf0 !important;
        border-color: #0dcaf0 !important;
    }

    .btn-outline-primary.no-hover-btn,
    .btn-outline-primary.no-hover-btn:hover {
        color: #0d6efd !important;
        border-color: #0d6efd !important;
    }
</style>
