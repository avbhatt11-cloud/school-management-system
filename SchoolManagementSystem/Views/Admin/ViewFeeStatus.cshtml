@model IEnumerable<SchoolManagementSystem.Models.FeePaymentViewModel>
@{
    ViewBag.Title = "View Fee Status";
}

<div class="d-flex justify-content-between align-items-center mb-4 profile">
    <h2 class="text-green mt-2 mb-2">

        <i class="bi bi-currency-rupee"></i>
        Fee Status - @ViewBag.ClassName
    </h2>
</div>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Student Name</th>
                <th>Class</th>
                <th>Fee Type</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Payment Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-capitalize">@item.StudentFirstName @item.StudentLastName</td>
                    <td>@item.ClassName</td>
                    <td>@item.FeeType</td>
                    <td>₹@item.Amount</td>
                    <td class="text-capitalize">
                        <span class="badge @(item.Status == "Paid" ? "bg-success" : "bg-warning")">
                            @item.Status
                        </span>
                    </td>
                    <td>@(item.PaymentDate != null ? item.PaymentDate.Value.ToString("dd MMM yyyy") : "-")</td>
                </tr>
            }
        </tbody>
    </table>
    <div class="mt-3">
        @Html.ActionLink("Back to Manage Fees", "ManageFees", null, new { @class = "btn btn-secondary" })
    </div>
</div>
<style>
    .profile-wrapper {
        margin: 30px;
        padding: 25px;
    }

    .profile {
        margin: 10px 30px;
    }
    .text-green {
        color: #2d5f5d !important;
    }
</style>