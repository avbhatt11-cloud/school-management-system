@model IEnumerable<SchoolManagementSystem.Models.Notification>

@{
    ViewBag.Title = "Manage Notification";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Admin Layout
}

<div class="container mt-4">
    <h2 class="mb-4">📢 Manage Notifications</h2>

    <!-- Add Notification Form -->
    @using (Html.BeginForm("CreateNotification", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="card shadow-sm p-4 mb-4">
            <div class="form-group mb-3">
                <label for="Role" class="fw-bold">Select Role</label>
                <select name="Role" class="form-control" required>
                    <option value="">-- Select Role --</option>
                    <option value="Staff">Staff</option>
                    <option value="Parent">Parent</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label for="Message" class="fw-bold">Message</label>
                <textarea name="Message" class="form-control" rows="3" placeholder="Enter notification message" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Send Notification</button>
        </div>
    }

    <!-- Notification Table -->
    <div class="card shadow-sm p-4">
        <h4 class="mb-3">📋 Existing Notifications</h4>
        <table class="table table-bordered table-hover text-center">
            <thead style="background-color:#2f294c; color:white;">
                <tr>
                    <th>#</th>
                    <th>Role</th>
                    <th>Message</th>
                    <th>Date Sent</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var notification in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@notification.Role</td>
                            <td>@notification.Message</td>
                            <td>@notification.CreatedDate.ToString("dd-MMM-yyyy hh:mm tt")</td>
                            <td>
                                @Html.ActionLink("🗑 Delete", "DeleteNotification", new { id = notification.Id },
                                    new { @class = "btn btn-danger btn-sm", onclick = "return confirm('Are you sure you want to delete this notification?');" })
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">No notifications found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
