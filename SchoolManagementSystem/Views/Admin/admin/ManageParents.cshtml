@model IEnumerable<SchoolManagementSystem.Models.Parent>

@{
    ViewBag.Title = "Manage Parents";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
    <h2 class="mb-2 mb-sm-0">Manage Parents</h2>
    <a class="btn btn-success" href="@Url.Action("CreateParent","Admin")">
        <i class="bi bi-plus-lg"></i> Add New Parent
    </a>
</div>

<!-- Search box -->
<div class="mb-3">
    <input type="text" id="parentsSearch" class="form-control" placeholder="Search parents...">
</div>

<table class="table table-bordered table-striped" id="parentsTable">
    <thead>
        <tr>
            <th>Parent Name</th>
            <th>Username</th>
            <th>Gender</th>
            <th>Contact</th>
            <th>Address</th>
            <th>Student Name</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var parent in Model)
        {
            <tr>
                <td>@(parent.ParentFirstName + " " + parent.ParentLastName)</td>
                <td>@parent.Username</td>
                <td>@parent.Gender</td>
                <td>@parent.ContactNumber</td>
                <td>@parent.Address</td>
                <td>
                    @if (!string.IsNullOrEmpty(parent.StudentMiddleName))
                    {
                        @(parent.StudentFirstName + " " + parent.StudentMiddleName + " " + parent.StudentLastName)
                    }
                    else
                    {
                        @(parent.StudentFirstName + " " + parent.StudentLastName)
                    }
                </td>
                <td>@parent.CreatedDate.ToString("dd-MMM-yyyy")</td>
                <td>
                    @Html.ActionLink("Edit", "EditParent", new { id = parent.ParentId }, new { @class = "btn btn-sm btn-warning" }) |
                    @Html.ActionLink("Details", "DetailsParent", new { id = parent.ParentId }, new { @class = "btn btn-sm btn-info" }) |
                    @Html.ActionLink("Delete", "DeleteParent", new { id = parent.ParentId }, new { @class = "btn btn-sm btn-danger" })
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- JavaScript for search -->
<script>
    document.getElementById("parentsSearch").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        let rows = document.querySelectorAll("#parentsTable tbody tr");
        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(value) ? "" : "none";
        });
    });
</script>
