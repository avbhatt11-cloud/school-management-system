@model SchoolManagementSystem.Models.Parent

@{
    ViewBag.Title = "Parent Details";
}

<h2>Parent Details</h2>

<div>
    <h4>Parent Information</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Student Name</dt>
        <dd>@Model.Student.FirstName @Model.Student.LastName</dd>

        <dt>Parent Name</dt>
        <dd>@Model.ParentFirstName @Model.ParentLastName</dd>

        <dt>Gender</dt>
        <dd>@Model.Gender</dd>

        <dt>Contact Number</dt>
        <dd>@Model.ContactNumber</dd>

        <dt>Address</dt>
        <dd>@Model.Address</dd>

        <dt>Created At</dt>
        <dd>@Model.CreatedAt</dd>

        <dt>Updated At</dt>
        <dd>@Model.UpdatedAt</dd>
    </dl>
</div>

<p>
    @Html.ActionLink("Edit", "EditParent", new { id = Model.ParentId }, new { @class = "btn btn-primary" }) |
    @Html.ActionLink("Back to List", "ManageParents", null, new { @class = "btn btn-secondary" })
</p>
