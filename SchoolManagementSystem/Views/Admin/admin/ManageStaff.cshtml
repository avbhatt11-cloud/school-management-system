@model IEnumerable<SchoolManagementSystem.Models.Staff>
@{
    ViewBag.Title = "Manage Staff";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Staff</h2>
    
    <div class="mb-3">
        <a class="btn btn-success" href="@Url.Action("CreateStaff","Admin")">Add New Staff</a>
        @if (ViewBag.ShowInactive == true)
        {
            <a href="@Url.Action("ManageStaff", new { showInactive = false })" class="btn btn-primary text-decoration-none">Show Active</a>
        }
        else
        {
            <a href="@Url.Action("ManageStaff", new { showInactive = true })" class="btn btn-secondary text-decoration-none">Show Inactive</a>
        }
    </div>
</div>

<!-- Toggle Active/Inactive -->


<!-- Search box -->
<div class="mb-3">
    <input type="text" id="staffSearch" class="form-control" placeholder="Search staff...">
</div>

<table class="table table-striped table-bordered" id="staffTable">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Photo</th>
            <th>Username</th>
            <th>Name</th>
            <th>Email</th>
            <th>Gender</th>
            <th>Contact</th>
            <th>Designation</th>
            <th>Class Assigned</th>
            <th>Status</th>
            <th style="width:220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            int i = 1;
            foreach (var item in Model)
            {
                <tr class="@(item.IsActive ? "" : "table-warning")">
                    <td>@i</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.PhotoPath))
                        {
                            <img src="@Url.Content(item.PhotoPath)" style="width:60px;height:60px;object-fit:cover;border-radius:4px" />
                        }
                    </td>
                    <td>@item.Username</td>
                    <td>@item.FirstName @item.LastName</td>
                    <td>@item.Email</td>
                    <td>@item.Gender</td>
                    <td>@item.ContactNo</td>
                    <td>@item.Designation</td>
                    <td>@item.ClassAssigned</td>
                    <td>@(item.IsActive ? "Active" : "Inactive")</td>
                    <td >
                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-outline-info" href="@Url.Action("DetailsStaff","Admin", new { id = item.Id })">Details</a>
                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("EditStaff","Admin", new { id = item.Id })">Edit</a>

                            @if (item.IsActive)
                            {
                                using (Html.BeginForm("DeleteStaff", "Admin", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", item.Id)
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Deactivate this staff?')">Deactivate</button>
                                }
                            }
                            else
                            {
                                using (Html.BeginForm("RestoreStaff", "Admin", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", item.Id)
                                    <button type="submit" class="btn btn-sm btn-success">Restore</button>
                                }
                            }
                        </div>
                    </td>
                </tr>
                i++;
            }
        }
    </tbody>
</table>

<!-- JavaScript for search -->
<script>
    document.getElementById("staffSearch").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        let rows = document.querySelectorAll("#staffTable tbody tr");
        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(value) ? "" : "none";
        });
    });
</script>
