@model SchoolManagementSystem.Models.TimeTable
@{
    ViewBag.Title = "Delete TimeTable Entry";
}
<div class="mt-3 mb-4 text-danger fw-bold profile">
    <h4 class="mb-0">
        <i class="bi bi-trash"></i> Confirm Delete
    </h4>
    </div>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-12">
                <div class="card shadow">
                    <div class="card-header bg-danger text-white">

                        <small>Class: <strong>@ViewBag.ClassAssigned</strong></small>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <strong>Warning!</strong> Are you sure you want to delete this timetable entry? This action cannot be undone.
                        </div>

                        <h5 class="mb-3">Entry Details:</h5>

                        <table class="table table-bordered">
                            <tr>
                                <th width="30%"><i class="bi bi-book"></i> Subject:</th>
                                <td>@Model.SubjectName</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-person"></i> Teacher:</th>
                                <td>@Model.TeacherName</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-calendar-day"></i> Day:</th>
                                <td>@Model.WeekDay</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-clock"></i> Time:</th>
                                <td>
                                    @Model.StartTime.ToString("hh:mm tt") - @Model.EndTime.ToString("hh:mm tt")
                                </td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-hourglass-split"></i> Duration:</th>
                                <td>@Model.DurationInMinutes minutes</td>
                            </tr>
                        </table>

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a href="@Url.Action("ManageTimeTable", "Staff")" class="btn btn-secondary">
                                <i class="bi"></i> Cancle
                            </a>

                            @using (Html.BeginForm("DeleteTimeTable", "Staff", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("id", Model.TimeTableId)
                                <button type="submit" class="btn btn-danger">
                                    <i class="bi"></i> Yes, Delete It
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
    <style>
        .profile-wrapper {
            margin: 30px;
            padding: 25px;
        }

        .profile {
            margin: 10px 30px;
        }

        .table-responsive {
            overflow-x: auto;
        }

        .badge {
            padding: 0.5em 0.75em;
            font-size: 0.875rem;
        }
    </style>
