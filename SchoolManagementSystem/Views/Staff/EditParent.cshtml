@model SchoolManagementSystem.Models.Parent

@{
    ViewBag.Title = "Edit Parent";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-4 profile mx-10">

    <h2 class="text-green mt-2 mb-2">✏ Edit Parent</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Close"></button>
    </div>
}

@using (Html.BeginForm("EditParent", "Staff", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ParentId)
    @Html.HiddenFor(m => m.ClassName)

    <div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

        <!-- =================== Student Details =================== -->
        <h4 class="fw-bold mb-3">Student Details</h4>
        <hr />

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.StudentFirstName, new { @class = "form-label fw-bold" }) <span class="required-star text-danger">*</span>
            @Html.TextBoxFor(m => m.StudentFirstName, new
            {
                @class = "form-control text-capitalize",
                placeholder = "Enter Student First Name",
                maxlength = "20",
                onkeypress = "return allowOnlyLetters(event)",
                oninput = "removeNonLetters(this)"
            })
            @Html.ValidationMessageFor(m => m.StudentFirstName, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.StudentMiddleName, new { @class = "form-label fw-bold" }) <span class="required-star text-danger">*</span>
            @Html.TextBoxFor(m => m.StudentMiddleName, new
            {
                @class = "form-control text-capitalize",
                placeholder = "Enter Student Middle Name",
                maxlength = "20",
                onkeypress = "return allowOnlyLetters(event)",
                oninput = "removeNonLetters(this)"
            })
            @Html.ValidationMessageFor(m => m.StudentMiddleName, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.StudentLastName, new { @class = "form-label fw-bold" }) <span class="required-star text-danger">*</span>
            @Html.TextBoxFor(m => m.StudentLastName, new
            {
                @class = "form-control text-capitalize",
                placeholder = "Enter Student Last Name",
                maxlength = "20",
                onkeypress = "return allowOnlyLetters(event)",
                oninput = "removeNonLetters(this)"
            })
            @Html.ValidationMessageFor(m => m.StudentLastName, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.StudentGender, new { @class = "form-label fw-bold" }) <span class="required-star text-danger">*</span>
            @Html.DropDownListFor(m => m.StudentGender, new SelectList(new[] { "Male", "Female", "Other" }, Model.StudentGender), "-- Select Gender --", new { @class = "form-select" })
            @Html.ValidationMessageFor(m => m.StudentGender, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.ClassName, new { @class = "form-label fw-bold" }) 
            @Html.TextBoxFor(m => m.ClassName, new
            {
                @class = "form-control",
                @readonly = "readonly"
            })
        </div>

        <!-- =================== Parent Details =================== -->
        <h4 class="fw-bold mt-5 mb-3">Parent Details</h4>
        <hr />

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.ParentFirstName, new { @class = "form-label fw-bold" }) <span class="required-star text-danger">*</span>
            @Html.TextBoxFor(m => m.ParentFirstName, new
            {
                @class = "form-control text-capitalize",
                placeholder = "Enter Parent First Name",
                maxlength = "20",
                onkeypress = "return allowOnlyLetters(event)",
                oninput = "removeNonLetters(this)"
            })
            @Html.ValidationMessageFor(m => m.ParentFirstName, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.ParentMiddleName, new { @class = "form-label fw-bold" }) <span class="required-star text-danger">*</span>
            @Html.TextBoxFor(m => m.ParentMiddleName, new
            {
                @class = "form-control text-capitalize",
                placeholder = "Enter Parent Middle Name",
                maxlength = "20",
                onkeypress = "return allowOnlyLetters(event)",
                oninput = "removeNonLetters(this)"
            })
            @Html.ValidationMessageFor(m => m.ParentMiddleName, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.ParentLastName, new { @class = "form-label fw-bold" }) <span class="required-star text-danger">*</span>
            @Html.TextBoxFor(m => m.ParentLastName, new
            {
                @class = "form-control text-capitalize",
                placeholder = "Enter Parent Last Name",
                maxlength = "20",
                onkeypress = "return allowOnlyLetters(event)",
                oninput = "removeNonLetters(this)"
            })
            @Html.ValidationMessageFor(m => m.ParentLastName, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.Gender, new { @class = "form-label fw-bold" }) <span class="required-star text-danger">*</span>
            @Html.DropDownListFor(m => m.Gender, new SelectList(new[] { "Male", "Female", "Other" }, Model.Gender), "-- Select Gender --", new { @class = "form-select" })
            @Html.ValidationMessageFor(m => m.Gender, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.ContactNumber, new { @class = "form-label fw-bold" })
            <span class="required-star text-danger">*</span>
            @Html.TextBoxFor(m => m.ContactNumber, new
            {
                @class = "form-control",
                placeholder = "Enter 10 digit contact number",
                maxlength = "10",
                onkeypress = "return allowOnlyDigits(event)",
                oninput = "validateContactNumber(this)"
            })
            @Html.ValidationMessageFor(m => m.ContactNumber, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.Email, new { @class = "form-label fw-bold" }) <span class="required-star text-danger">*</span>
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Enter Email" })
            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.Address, new { @class = "form-label fw-bold" })
            <span class="required-star text-danger">*</span>
            @Html.TextAreaFor(m => m.Address, new
            {
                @class = "form-control",
                maxlength = "100",
                rows = 2,
                placeholder = "Enter Address"
            })
            @Html.ValidationMessageFor(m => m.Address, "", new { @class = "text-danger" })
        </div>

        <!-- Username -->
        <div class="col-md-4 col-sm-6">
            <div class="mb-1">
                @Html.LabelFor(m => m.Username, new { @class = "form-label fw-bold" })
                <span class="text-danger">*</span>
                @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Enter username", required = "required" })
                @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
            </div>
        </div>

        <!-- Password -->
        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.Password, new { @class = "form-label fw-bold" })
            <span class="text-muted">(Leave blank to keep current)</span>

            <div class="input-group">
                @Html.PasswordFor(m => m.Password, new
                {
                    @class = "form-control",
                    id = "Password",
                    maxlength = "8",
                    placeholder = "Leave blank to keep old password",
                    value = ""
                })
                <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                    <i class="bi bi-eye" id="eyeIconPassword"></i>
                </button>
            </div>

            <small class="text-muted">5-8 characters, letters &amp; numbers only. Example: Abc123</small>
            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
        </div>

        <!-- Confirm Password -->
        <div class="col-md-4 col-sm-6">
            @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label fw-bold" })
            <span class="text-muted">(Required if changing password)</span>

            <div class="input-group">
                @Html.PasswordFor(m => m.ConfirmPassword, new
                {
                    @class = "form-control",
                    id = "ConfirmPassword",
                    maxlength = "8",
                    placeholder = "Fill only if changing password"
                })
                <button class="btn btn-outline-secondary" type="button" id="toggleConfirmPassword">
                    <i class="bi bi-eye" id="eyeIconConfirmPassword"></i>
                </button>
            </div>

            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
        </div>

        <!-- Buttons -->
        <div class="mt-4">
            <button type="submit" class="btn btn-success px-4 me-2">Update</button>
            <a href="@Url.Action("ManageParents","Staff")" class="btn btn-secondary px-4">Cancel</a>
        </div>
    </div>
}

<style>
    .profile-wrapper {
        margin: 30px;
        padding: 25px;
    }

    .profile {
        margin: 10px 30px;
    }

    .profile1 {
        margin: 10px 30px;
        margin-left: 100px;
    }

    .text-green {
        color: #2d5f5d !important;
    }

    .btn-theme {
        background-color: #2d5f5d;
        color: white;
        border: none;
    }

        .btn-theme:hover {
            background-color: #234b49;
            color: white;
        }

    h4 {
        color: #ff6b6b;
    }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function allowOnlyLetters(event) {
        var charCode = event.which ? event.which : event.keyCode;
        if ((charCode >= 65 && charCode <= 90) ||
            (charCode >= 97 && charCode <= 122) ||
            charCode == 8 || charCode == 9 || charCode == 46 ||
            (charCode >= 37 && charCode <= 40)) {
            return true;
        }
        event.preventDefault();
        return false;
    }

    function removeNonLetters(input) {
        input.value = input.value.replace(/[^A-Za-z]/g, '');
    }

    function allowOnlyDigits(event) {
        var charCode = event.which ? event.which : event.keyCode;
        if ((charCode >= 48 && charCode <= 57) ||
            (charCode >= 96 && charCode <= 105) ||
            charCode == 8 || charCode == 9 || charCode == 46 ||
            (charCode >= 37 && charCode <= 40)) {
            return true;
        }
        event.preventDefault();
        return false;
    }

    function validateContactNumber(input) {
        input.value = input.value.replace(/[^0-9]/g, '');
        if (input.value.length > 10) {
            input.value = input.value.slice(0, 10);
        }
    }

    $(document).ready(function () {

        $("#togglePassword").on("click", function () {
            const field = $("#Password");
            const icon = $("#eyeIconPassword");
            const type = field.attr("type") === "password" ? "text" : "password";
            field.attr("type", type);
            icon.toggleClass("bi-eye bi-eye-slash");
        });

        $("#toggleConfirmPassword").on("click", function () {
            const field = $("#ConfirmPassword");
            const icon = $("#eyeIconConfirmPassword");
            const type = field.attr("type") === "password" ? "text" : "password";
            field.attr("type", type);
            icon.toggleClass("bi-eye bi-eye-slash");
        });

        $("#Password, #ConfirmPassword").on("keyup", function () {
            const p = $("#Password").val();
            const c = $("#ConfirmPassword").val();

            if (p === "" && c === "") {
                $("span[data-valmsg-for='ConfirmPassword']").text("");
                return;
            }

            if (p !== c) {
                $("span[data-valmsg-for='ConfirmPassword']").text("Password and Confirm Password do not match");
            } else {
                $("span[data-valmsg-for='ConfirmPassword']").text("");
            }
        });

    });
</script>
