@model SchoolManagementSystem.Models.ExamSchedule
@{
    ViewBag.Title = "Post Exam Schedule";
}

<div class="d-flex justify-content-between align-items-center mb-4 profile mx-10">

    <h2 class="text-green mt-2 mb-2"> <i class="bi bi-clock-history"></i> Post Exam Schedule</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">
    @using (Html.BeginForm("PostExamSchedule", "Staff", FormMethod.Post, new { enctype = "multipart/form-data", id = "examScheduleForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="form-group mb-3">
            <label class="form-label fw-bold">
                Class Name
            </label>
            <input type="text"
                   class="form-control"
                   value="@ViewBag.StaffClass"
                   disabled
                   readonly />
        </div>

        <div class="form-group mb-3">
            <label class="form-label fw-bold">
                Exam Type <span class="text-danger">*</span>
            </label>
            <select name="ExamType" class="form-control" required>
                <option value="">Select Exam Type</option>
                <option value="Mid-Term">Mid-Term</option>
                <option value="Final">Final</option>
            </select>
            @Html.ValidationMessage("ExamType", "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
            <label class="form-label fw-bold">
                 Upload Schedule File <span class="text-danger">*</span>
            </label>
            <input type="file"
                   name="ScheduleFile"
                   id="ScheduleFile"
                   class="form-control"
                   accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                   required
                   onchange="validateFile(this)" />
            <small class="text-muted">Max file size: 10MB | Allowed: PDF, DOC, DOCX, JPG, PNG</small>
            @Html.ValidationMessage("ScheduleFile", "", new { @class = "text-danger" })
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="bi bi-upload"></i> Post Schedule
        </button>
        <button type="button" class="btn btn-secondary" onclick="resetExamScheduleForm()">
            <i class="bi bi-x-circle"></i> Cancel
        </button>
    }

    <hr class="my-4" />

    <h3 class="mb-3"><i class="fa fa-clock"></i> Existing Exam Schedules</h3>

    @if (ViewBag.ExamSchedules != null && ((List<SchoolManagementSystem.Models.ExamSchedule>)ViewBag.ExamSchedules).Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>No.</th>
                        <th>Class</th>
                        <th>Exam Type</th>
                        <th>Schedule File</th>
                        <th>Posted By</th>
                        <th>Posted On</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1;}

                    @foreach (var item in ViewBag.ExamSchedules as List<SchoolManagementSystem.Models.ExamSchedule>)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@item.ClassName</td>
                            <td>
                                <span class="badge @(item.ExamType == "Mid-Term" ? "bg-info" : "bg-warning")">
                                    @item.ExamType
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ScheduleFileName))
                                {
                                    <a href="@Url.Action("ViewExamScheduleFile", "Staff", new { id = item.Id })"
                                       target="_blank"
                                       class="text-primary text-decoration-none"
                                       title="Click to view file">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                        <span>@item.ScheduleFileName</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">No file</span>
                                }
                            </td>
                            <td>@item.CreatedBy</td>
                            <td>@item.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</td>
                            <td>
                                <form method="post"
                                      action="@Url.Action("DeleteExamSchedule", "Staff", new { id = item.Id })"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Are you sure you want to delete this exam schedule?');"
                                            title="Delete">
                                        <i class="bi"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No exam schedules posted yet for your class.
        </div>
    }
</div>

<style>
    .profile-wrapper {
        margin: 30px; /* outside space */
        padding: 25px; /* inside space */
    }

    .profile {
        margin: 10px 30px;
        /*        padding: 15px;  inside space */
    }

    .profile1 {
        margin: -10px;
    }

    .text-green {
        color: #2d5f5d !important;
    }

    .btn-theme {
        background-color: #2d5f5d;
        color: white;
        border: none;
    }

        .btn-theme:hover {
            background-color: #234b49;
            color: white;
        }

    h3 {
        color: #ff6b6b;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .badge {
        padding: 0.5em 0.75em;
        font-size: 0.875rem;
    }

    .table a:hover {
        text-decoration: underline !important;
    }
</style>

<script>
    function validateFile(input) {
        const file = input.files[0];
        if (file) {
            // Check file size (10MB = 10 * 1024 * 1024 bytes)
            const maxSize = 10 * 1024 * 1024;
            if (file.size > maxSize) {
                alert('File size must not exceed 10MB!');
                input.value = '';
                return false;
            }

            // Check file name length
            if (file.name.length > 100) {
                alert('File name is too long! Please rename the file to less than 100 characters.');
                input.value = '';
                return false;
            }

            // Check file extension
            const allowedExtensions = ['.pdf', '.doc', '.docx', '.jpg', '.jpeg', '.png'];
            const fileExtension = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
            if (!allowedExtensions.includes(fileExtension)) {
                alert('Invalid file type! Only PDF, DOC, DOCX, JPG, and PNG files are allowed.');
                input.value = '';
                return false;
            }
        }
    }
    // Reset exam schedule form function
    function resetExamScheduleForm() {
        var form = document.getElementById("examScheduleForm");

        // Form reset
        form.reset();

        // File input ko clear karo
        document.getElementById("ScheduleFile").value = "";

        // Validation messages clear karo
        var validationMessages = form.querySelectorAll('.text-danger');
        validationMessages.forEach(function (msg) {
            msg.innerHTML = "";
        });

        // Validation classes remove karo (if any)
        form.classList.remove('was-validated');
    }
</script>