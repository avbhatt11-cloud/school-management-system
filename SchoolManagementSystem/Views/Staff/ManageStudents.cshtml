@model IEnumerable<SchoolManagementSystem.Models.Student>
@{
    ViewBag.Title = "Manage Students";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Manage Students</h2>
        <a href="@Url.Action("CreateStudent", "Staff")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Student
        </a>
    </div>

    <!-- Search box -->
    <div class="mb-3">
        <input type="text" id="studentSearch" class="form-control" placeholder="Search students...">
    </div>

    <table class="table table-striped table-bordered table-hover" id="studentsTable">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Full Name</th>
                <th>Gender</th>
                <th>Class</th>
                <th>Parent Name</th>
                <th>Contact</th>
                <th>Address</th>
                <th>Created At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var student in Model)
                {
                    <tr>
                        <td>@student.Id</td>
                        <td>@student.FirstName @student.MiddleName @student.LastName</td>
                        <td>@student.Gender</td>
                        <td>@student.ClassName</td>
                        <td>@student.ParentFirstName @student.ParentLastName</td>
                        <td>@student.ContactNumber</td>
                        <td>@student.Address</td>
                        <td>@student.CreatedAt.ToString("dd-MMM-yyyy")</td>
                        <td>
                            <a href="@Url.Action("EditStudent", "Staff", new { id = student.Id })" class="btn btn-warning btn-sm">Edit</a>
                            <a href="@Url.Action("DetailsStudent", "Staff", new { id = student.Id })" class="btn btn-info btn-sm">Details</a>
                            <a href="@Url.Action("DeleteStudent", "Staff", new { id = student.Id })" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?')">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center text-muted">No students found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- JavaScript for search -->
<script>
    document.getElementById("studentSearch").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        let rows = document.querySelectorAll("#studentsTable tbody tr");
        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(value) ? "" : "none";
        });
    });
</script>
