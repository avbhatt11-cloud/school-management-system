@model IEnumerable<SchoolManagementSystem.Models.TimeTable>
@{
    ViewBag.Title = "ViewTimeTable";
}

<div class="mb-4 mt-3 text-primary fw-bold profile">
    <h2>📅 Class Time Table</h2>
    @if (ViewBag.ChildClass != null)
    {
        <p class="text-muted">Viewing timetable for: <strong class="text-success">@ViewBag.ChildClass</strong></p>
    }
</div>

<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">
    @using (Html.BeginForm("ViewTimeTable", "Parent", FormMethod.Get, new { id = "dayForm" }))
    {
        <div class="row mb-4">
            <div class="col-md-4">
                <label class="form-label fw-semibold">
                    Select Day <span class="text-danger">*</span>
                </label>
                @Html.DropDownList(
                    "selectedDay",
                    (SelectList)ViewBag.Days,
                    "-- Select Day --",
                    new
                    {
                        @class = "form-select shadow-sm",
                        id = "selectedDay",
                        onchange = "submitDayForm();"
                    }
                )
            </div>
        </div>
    }

    @* Show message if present *@
    @if (ViewBag.Message != null)
    {
        <div class="alert alert-warning mt-3">
            <i class="bi bi-info-circle"></i> @ViewBag.Message
        </div>
    }

    @* Show error if present *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-3">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
        </div>
    }

    @* Show timetable only if data exists *@
    @if (Model != null && Model.Any())
    {
        <div class="card shadow-lg rounded-3">
            <div class="card-body p-0">
                <table class="table table-striped table-hover table-bordered align-middle mb-0">
                    <thead class="table-primary text-center">
                        <tr>
                            <th>📖 Subject</th>
                            <th>👨‍🏫 Teacher</th>
                            <th>⏰ Start Time</th>
                            <th>⏳ End Time</th>
                            <th>🕒 Duration (Minutes)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="text-center">
                                <td class="fw-semibold text-capitalize">@item.SubjectName</td>
                                <td class="text-capitalize">@item.TeacherName</td>
                                <td>@item.StartTime.ToString("hh:mm tt")</td>
                                <td>@item.EndTime.ToString("hh:mm tt")</td>
                                <td class="text-center">@item.DurationInMinutes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .profile-wrapper {
        margin: 30px;
        padding: 25px;
    }

    .profile {
        margin: 10px 30px;
    }
</style>

<script>
    function submitDayForm() {
        document.getElementById("dayForm").submit();
    }
</script>