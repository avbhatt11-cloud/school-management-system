@model SchoolManagementSystem.Models.Parent

@{
    ViewBag.Title = "Delete Parent";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<h2 class="mt-3 mb-4 text-danger fw-bold profile">🗑 Delete Parent</h2>


<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <div class="alert alert-warning">
        <p>Are you sure you want to delete this parent?</p>
        <strong>@($"{Model.ParentFirstName} {Model.ParentLastName}")</strong>
    </div>

    @using (Html.BeginForm("DeleteParent", "Staff", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.ParentId)

        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="@Url.Action("ManageParents", "Staff")" class="btn btn-secondary">Cancel</a>
    }
</div>
<style>
    .profile-wrapper {
        margin: 30px;
        padding: 25px;
    }

    .profile {
        margin: 10px 30px;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .badge {
        padding: 0.5em 0.75em;
        font-size: 0.875rem;
    }
</style>