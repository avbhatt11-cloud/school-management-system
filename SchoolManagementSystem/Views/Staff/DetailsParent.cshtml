@model SchoolManagementSystem.Models.Parent

@{
    ViewBag.Title = "Parent Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-4 profile mx-10">

    <h2 class="text-green mt-2 mb-2">
        <i class="bi bi-people me-1"></i>
        Parent Details
    </h2>
</div>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <div class="card shadow p-4">
        <h4 class="fw-bold mb-3">Student Information</h4>
        <dl class="row">
            <dt class="col-sm-3">Student Name</dt>
            <dd class="col-sm-9 text-capitalize">@($"{Model.StudentFirstName} {Model.StudentLastName}")</dd>

            <dt class="col-sm-3">Gender</dt>
            <dd class="col-sm-9">@Model.StudentGender</dd>

            <dt class="col-sm-3">Class</dt>
            <dd class="col-sm-9">@Model.ClassName</dd>
        </dl>
        <hr />
        <h4 class=" fw-bold mt-4 mb-3">Parent Information</h4>
        <dl class="row">
            <dt class="col-sm-3">Parent Name</dt>
            <dd class="col-sm-9 text-capitalize">@($"{Model.ParentFirstName} {Model.ParentLastName}")</dd>

            <dt class="col-sm-3">Contact No</dt>
            <dd class="col-sm-9">@Model.ContactNumber</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Address</dd>

            <dt class="col-sm-3">Username</dt>
            <dd class="col-sm-9">@Model.Username</dd>

            <dt class="col-sm-3">Password</dt>
            <dd class="col-sm-9">@Model.Password</dd>

        </dl>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("ManageParents", "Staff")" class="btn btn-secondary"> Back to list</a>
        <a href="@Url.Action("EditParent", "Staff", new { id = Model.ParentId })" class="btn btn-warning"> Edit</a>
        <a href="@Url.Action("DeleteParent", "Staff", new { id = Model.ParentId })"
           class="btn btn-danger"
           onclick="return confirm('Are you sure you want to delete this parent?');"> Delete</a>
    </div>

</div>
    <style>
        .profile-wrapper {
            margin: 30px; /* outside space */
            padding: 25px; /* inside space */
        }

        .profile {
            margin: 10px 30px;
            /*        padding: 15px;  inside space */
        }

        .profile1 {
            margin: 10px 30px;
            margin-left: 100px;
        }

        .text-green {
            color: #2d5f5d !important;
        }

        .btn-theme {
            background-color: #2d5f5d;
            color: white;
            border: none;
        }

            .btn-theme:hover {
                background-color: #234b49;
                color: white;
            }

        h4 {
            color: #ff6b6b;
        }
    </style>