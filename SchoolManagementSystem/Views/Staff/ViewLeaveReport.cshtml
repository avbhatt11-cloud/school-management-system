@model IEnumerable<SchoolManagementSystem.Models.LeaveReport>
@{
    ViewBag.Title = "View Leave Report";
}
<div class="d-flex justify-content-between align-items-center mb-4 profile mx-10">

    <h2 class="text-green mt-2 mb-2"> <i class="bi bi-person-dash"></i> View Leave Report</h2>

</div>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <table class="table table-bordered table-striped" style="table-layout: fixed; word-wrap: break-word;">
        <thead class="table-dark">
            <tr>
                <th style="width:4%">No.</th>
                <th style="width:10%">Student</th>
                <th style="width:6%">Class</th>
                <th style="width:8%">Title</th>
                <th style="width:15%">Reason</th>
                <th style="width:12%">Dates</th>
                <th style="width:4%">Days</th>
                <th style="width:7%">Status</th>
                <th style="width:10%">Attachment</th>
                <th style="width:10%">Submitted At</th>
                <th style="width:14%">Action</th>
            </tr>
        </thead>
        <tbody>
            @{int i = 1;}
            @foreach (var report in Model)
            {

                <tr>
                    <td>@i</td>
                    <td class="text-capitalize text-Secondary fw-semibold">
                        @(report.Parent != null
                           ? (report.Parent.StudentFirstName + " " + report.Parent.StudentMiddleName + " " + report.Parent.StudentLastName)
                      : "-")
                    </td>

                    <td>@(report.Parent != null ? report.Parent.ClassName : "-")</td>

                    <td class="text-capitalize">@report.Title</td>
                    <td class="text-capitalize">@report.Reason</td>
                    <td>@(report.StartDate?.ToString("yyyy-MM-dd")) <b>TO</b> @(report.EndDate?.ToString("yyyy-MM-dd"))</td>

                    <td>@report.Days</td>
                    <td>@report.Status</td>
                    <td>
                        @if (!string.IsNullOrEmpty(report.AttachmentPath))
                        {
                            <a href="@Url.Content(report.AttachmentPath)" target="_blank">
                                @report.AttachmentFileName
                            </a>
                            <div><small>@(report.AttachmentSize/1024) KB</small></div>
                        }
                    </td>
                    <td>@report.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @if (report.Status == "Pending")
                        {
                            <a class="btn btn-sm btn-success"
                               href="@Url.Action("ApproveLeave", "Staff", new { id = report.Id })">Approve</a>
                            <a class="btn btn-sm btn-danger"
                               href="@Url.Action("RejectLeave", "Staff", new { id = report.Id })">Reject</a>
                        }
                        else
                        {
                            <span>@report.Status</span>
                        }
                    </td>


                </tr>
                i++;
            }

        </tbody>
    </table>
</div>
    <style>
        .profile-wrapper {
            margin: 30px; /* outside space */
            padding: 25px; /* inside space */
        }

        .profile {
            margin: 10px 30px;
            /*        padding: 15px;  inside space */
        }

        .profile1 {
            margin: -10px;
        }

        .text-green {
            color: #2d5f5d !important;
        }

        .btn-theme {
            background-color: #2d5f5d;
            color: white;
            border: none;
        }

            .btn-theme:hover {
                background-color: #234b49;
                color: white;
            }

        h3 {
            color: #ff6b6b;
        }
        .table td, .table th {
            word-break: break-word;
            white-space: normal;
            vertical-align: middle;
        }
    </style>
