@model IEnumerable<SchoolManagementSystem.Models.Material>
@{
    ViewBag.Title = "Upload Material";
}

<div class="d-flex justify-content-between align-items-center mb-4 profile mx-10">

    <h2 class="text-green mt-2 mb-2"><i class="bi bi-cloud-upload"></i> Upload Material - Class @ViewBag.ClassAssigned</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["Success"]
        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        @TempData["Error"]
        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Close"></button>
    </div>
}

<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <div class="card mb-4 p-3 ">
        @using (Html.BeginForm("UploadMaterial", "Staff", FormMethod.Post,
    new { enctype = "multipart/form-data", id = "uploadForm" }))
        {
            @Html.AntiForgeryToken()

            <div class="row mb-2">
                <div class="col-md-4 fw-bold">
                    @Html.Label("Title")
                    <span class="required-star">*</span>
                    @Html.TextBox("Title", null, new
                    {
                        @class = "form-control",
                        maxlength = "30",
                        required = "required",
                        placeholder = "Enter material title"
                    })
                    @Html.ValidationMessage("Title", "", new { @class = "text-danger" })
                </div>

                <div class="col-md-8">
                    @Html.Label("File", htmlAttributes: new { @class = "fw-bold" })
                    <span class="required-star">*</span>
                    <input type="file"
                           name="file"
                           id="materialFile"
                           class="form-control"
                           accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.jpg,.jpeg,.png,.mp4"
                           required
                           onchange="validateFile(this)" />
                    <small class="text-muted">Max file size: 20 MB | Allowed: PDF, DOC, DOCX, PPT, PPTX, XLS, XLSX, JPG, PNG, MP4</small>
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-md-12 fw-bold">
                    @Html.Label("Description")
                    <span class="required-star">*</span>
                    @Html.TextArea("Description", null, new
                    {
                        @class = "form-control",
                        rows = "3",
                        maxlength = "100",
                        required = "required",
                        placeholder = "Enter material description"
                    })
                    @Html.ValidationMessage("Description", "", new { @class = "text-danger" })
                </div>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-upload"></i> Upload
            </button>
            <button type="button" class="btn btn-secondary" onclick="resetUploadForm()">
                <i class="bi bi-x-circle"></i> Cancel
            </button>
        }
    </div>

    <h3><i class="fa fa-cloud-upload-alt"></i> Materials</h3>
    <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>No.</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Class</th>
                    <th>File</th>
                    <th>Uploaded By</th>
                    <th>Uploaded At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var m in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@m.Title</td>
                            <td>@m.Description</td>
                            <td>@m.ClassName</td>
                            <td>
                                <a href="@Url.Action("DownloadMaterial","Staff", new { id = m.Id })"
                                   class="text-primary text-decoration-none"
                                   title="Click to download">
                                    <i class="bi bi-file-earmark-arrow-down"></i>
                                    @m.FileName
                                </a>
                                <div><small class="text-muted">@(m.FileSize.HasValue ? (m.FileSize / 1024) + " KB" : "")</small></div>
                            </td>
                            <td>@(m.Staff != null ? (m.Staff.FirstName + " " + m.Staff.LastName) : "Unknown")</td>
                            <td>@m.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</td>
                            <td>
                                @using (Html.BeginForm("DeleteMaterial", "Staff", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", m.Id)
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Are you sure you want to delete this material?');"
                                            title="Delete">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">
                            <i class="bi bi-inbox"></i> No materials found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .profile-wrapper {
        margin: 30px; /* outside space */
        padding: 25px; /* inside space */
    }

    .profile {
        margin: 10px 30px;
        /*        padding: 15px;  inside space */
    }

    .profile1 {
        margin: -10px;
    }

    .text-green {
        color: #2d5f5d !important;
    }

    .btn-theme {
        background-color: #2d5f5d;
        color: white;
        border: none;
    }

        .btn-theme:hover {
            background-color: #234b49;
            color: white;
        }

    h3 {
        color: #ff6b6b;
    }
    .required-star {
        color: red;
        font-weight: bold;
        margin-left: 3px;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .table a:hover {
        text-decoration: underline !important;
    }
</style>

<script>
    function validateFile(input) {
        // If no file selected
        if (!input.files || input.files.length === 0) {
            return true;
        }

        const file = input.files[0];

        // ✅ 1. CHECK FILE SIZE (Maximum 20 MB)
        const maxSize = 20 * 1024 * 1024; // 20 MB in bytes
        if (file.size > maxSize) {
            const fileSizeMB = (file.size / (1024 * 1024)).toFixed(2);
            alert(`File size is ${fileSizeMB} MB. Maximum allowed size is 20 MB. Please select a smaller file.`);
            input.value = '';
            return false;
        }

        // ✅ 2. CHECK FILE NAME LENGTH (Maximum 150 characters)
        if (file.name.length > 150) {
            alert('File name is too long. Please rename the file to less than 150 characters.');
            input.value = '';
            return false;
        }

        // ✅ 3. CHECK FILE EXTENSION
        const allowedExtensions = ['.pdf', '.doc', '.docx', '.ppt', '.pptx', '.xls', '.xlsx', '.jpg', '.jpeg', '.png', '.mp4'];
        const fileExtension = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();

        if (!allowedExtensions.includes(fileExtension)) {
            alert('Invalid file type! Only PDF, DOC, DOCX, PPT, PPTX, XLS, XLSX, JPG, PNG, and MP4 files are allowed.');
            input.value = '';
            return false;
        }

        // ✅ Show file size info
        const fileSizeMB = (file.size / (1024 * 1024)).toFixed(2);
        console.log(`File selected: ${file.name} (${fileSizeMB} MB)`);

        return true;
    }
    // Reset upload form function
    function resetUploadForm() {
        var form = document.getElementById("uploadForm");

        // Form reset
        form.reset();

        // File input ko clear karo
        document.getElementById("materialFile").value = "";

        // Validation messages clear karo
        var validationMessages = form.querySelectorAll('.text-danger');
        validationMessages.forEach(function (msg) {
            msg.innerHTML = "";
        });

        // Validation classes remove karo (if any)
        form.classList.remove('was-validated');
    }
</script>