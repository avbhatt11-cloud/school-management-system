@model IEnumerable<SchoolManagementSystem.Models.Parent>
@{
    ViewBag.Title = "ManageStudentsAttendance";
}
<div class="d-flex justify-content-between align-items-center mb-4 profile mx-10">

    <h2 class="text-green mt-2 mb-2"><i class="bi bi-clipboard-check"></i> Class @ViewBag.ClassName Attendance</h2>

    @Html.ActionLink("📊 Attendance Report", "AttendanceReport", "Staff", null,
        new
        {
            @class = "btn btn-sm btn-outline-color me-2",
            
        })
</div>


@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Message"]
        <button type="button"
                class="btn-close "
                data-bs-dismiss="alert"
                aria-label="Close"></button>
    </div>
}
@using (Html.BeginForm("SaveAttendance", "Staff", FormMethod.Post,
        new { @class = "needs-validation", novalidate = "novalidate", id = "attendanceForm" }))
{
    <div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">
        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>No.</th>
                    <th>Student Name</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @{
                    int index = 0;
                }
                @foreach (var parent in Model)
                {
                    <tr>
                        <td>@(index + 1)</td>   <!-- Serial Number -->

                        <td>@parent.StudentFirstName @parent.StudentLastName</td>
                        <td>
                            <input type="hidden" name="parentIds[@index]" value="@parent.ParentId" />
                            <select name="statuses[@index]" class="form-control" required>
                                <option value="">--Select--</option>
                                <option value="Present">Present</option>
                                <option value="Absent">Absent</option>
                                <option value="Late">Late</option>
                            </select>
                            <div class="invalid-feedback">
                                Please select attendance status.
                            </div>


                        </td>
                    </tr>
                    index++;
                }

            </tbody>
        </table>
        <div class="mt-4 profile1">
            @if (ViewBag.AttendanceAlreadyMarked == true)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <strong>Attendance has already been marked for today!</strong>
                </div>
                <button type="submit" class="btn btn-primary me-2" disabled>Save Attendance</button>
            }
            else
            {
                <button type="submit" class="btn btn-primary me-2">Save Attendance</button>
            }
            <button type="button" class="btn btn-secondary" onclick="resetForm()">Cancel</button>
        </div>
    </div>
}
<style>
    .profile-wrapper {
        margin: 30px; /* outside space */
        padding: 25px; /* inside space */
    }

    .profile {
        margin: 10px 30px;
        /*        padding: 15px;  inside space */
    }

    .profile1 {
        margin: 10px 30px;
        margin-left: 100px;
    }

    .text-green {
        color: #2d5f5d !important;
    }

    .btn-theme {
        background-color: #2d5f5d;
        color: white;
        border: none;
    }

        .btn-theme:hover {
            background-color: #234b49;
            color: white;
        }

    h4 {
        color: #ff6b6b;
    }

    .profile1 {
        margin: -8px;
    }

    .btn-outline-color {
        color: #2d5f5d;
        border: 2px solid #2d5f5d;
        background: transparent;
    }

        .btn-outline-color:hover {
            background: #ff6b6b;
            color: white;
        }
</style>
<script>
    // Form validation
    (function () {
        'use strict'
        var forms = document.querySelectorAll('.needs-validation')
        Array.prototype.slice.call(forms)
            .forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
    })()

    // Reset form function
    function resetForm() {
        var form = document.getElementById('attendanceForm');

        // Form reset
        form.reset();

        // Remove validation classes
        form.classList.remove('was-validated');

        // All select elements ko default value par set karo
        var selects = form.querySelectorAll('select');
        selects.forEach(function (select) {
            select.selectedIndex = 0;
        });
    }
</script>