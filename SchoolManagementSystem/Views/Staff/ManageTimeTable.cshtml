@model SchoolManagementSystem.Models.TimeTable
@{
    ViewBag.Title = "Manage TimeTable";
}

<div class="d-flex justify-content-between align-items-center mb-4 profile mx-10">

    <h2 class="text-green mt-2 mb-2"><i class="bi bi-calendar-week"></i>

     Manage TimeTable for Class: <span>@ViewBag.ClassAssigned</span>
</h2>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Message"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close"></button>
            </div>
        }


        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close"></button>
            </div>
        }
</div>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">

    <div class="row">
        <!-- Add TimeTable Form -->


        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Add New TimeTable Entry</h5>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("ManageTimeTable", "Staff", FormMethod.Post, new { @class = "needs-validation", id = "timetableForm" }))
                    {
                        @Html.AntiForgeryToken()

                        <div class="mb-3 fw-bold">
                            @Html.LabelFor(m => m.SubjectName, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.SubjectName, new { @class = "form-control", placeholder = "e.g., Mathematics", required = "required" })
                            @Html.ValidationMessageFor(m => m.SubjectName, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3 fw-bold">
                            @Html.LabelFor(m => m.TeacherName, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.TeacherName, new { @class = "form-control", placeholder = "e.g., Mr. Kumar", required = "required" })
                            @Html.ValidationMessageFor(m => m.TeacherName, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3 fw-bold">
                            @Html.LabelFor(m => m.WeekDay, new { @class = "form-label" })
                            @Html.DropDownListFor(m => m.WeekDay, (SelectList)ViewBag.WeekDays, "Select Day", new { @class = "form-select", required = "required" })
                            @Html.ValidationMessageFor(m => m.WeekDay, "", new { @class = "text-danger" })
                        </div>

                        <div class="row">
                            <div class="col-md-3 mb-3 fw-bold">
                                @Html.LabelFor(m => m.StartTime, new { @class = "form-label" })
                                @Html.TextBoxFor(m => m.StartTime, "{0:HH:mm}", new { type = "time", @class = "form-control", onchange = "calculateDuration()", id = "StartTime", required = "required" })
                                @Html.ValidationMessageFor(m => m.StartTime, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-3 mb-3 fw-bold">
                                @Html.LabelFor(m => m.EndTime, new { @class = "form-label" })
                                @Html.TextBoxFor(m => m.EndTime, "{0:HH:mm}", new { type = "time", @class = "form-control", onchange = "calculateDuration()", id = "EndTime", required = "required" })
                                @Html.ValidationMessageFor(m => m.EndTime, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="mb-3 fw-bold">
                            @Html.LabelFor(m => m.DurationInMinutes, "Duration (Minutes)", new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.DurationInMinutes, new { @class = "form-control", @readonly = "readonly", id = "DurationInMinutes" })
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary flex-fill">
                                <i class="bi bi-plus-lg"></i> Add to TimeTable
                            </button>
                            <button type="button" class="btn btn-secondary flex-fill" onclick="resetTimetableForm()">
                                <i class="bi bi-x-circle"></i> Cancel
                            </button>
                        </div>

                    }
                </div>
            </div>
        </div>

        <!-- View TimeTable Entries -->
        <div class="view">
            <div class="col-md-12">
                <div class="card shadow-sm">
                    <div class="card-header text-black">
                        <h5 class="mb-0"><i class="bi bi-calendar-week"></i> Current TimeTable Entries</h5>
                    </div>
                    <div class="card-body">
                        @if (ViewBag.TimeTableEntries != null && ((List<SchoolManagementSystem.Models.TimeTable>)ViewBag.TimeTableEntries).Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>No.</th>
                                            <th>Day</th>
                                            <th>Subject</th>
                                            <th>Teacher</th>
                                            <th>Time</th>
                                            <th>Duration</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                       @{ int i = 1;
                                       }
                                        @foreach (var entry in (List<SchoolManagementSystem.Models.TimeTable>)ViewBag.TimeTableEntries)
                                        {

                                            <tr>
                                                <td>@i</td>
                                                <td><strong>@entry.WeekDay</strong></td>
                                                <td>@entry.SubjectName</td>
                                                <td>@entry.TeacherName</td>
                                                <td>
                                                    <span class="text-muted">
                                                        @entry.StartTime.ToString("hh:mm tt") - @entry.EndTime.ToString("hh:mm tt")
                                                    </span>
                                                </td>
                                                <td>@entry.DurationInMinutes min</td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        @*<a href="@Url.Action("ViewTimeTable", "Staff", new { id = entry.TimeTableId })"
                           class="btn btn-info" title="View Details">
                            <i class="bi bi-eye"></i>
                        </a>*@
                                                        <a href="@Url.Action("EditTimeTable", "Staff", new { id = entry.TimeTableId })"
                                                           class="btn btn-warning" title="Edit">
                                                            <i class="bi bi-pencil-square"></i>
                                                        </a>
                                                        <a href="@Url.Action("DeleteTimeTable", "Staff", new { id = entry.TimeTableId })"
                                                           class="btn btn-danger" title="Delete">
                                                            <i class="bi bi-trash"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                            i++;
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- Weekly View Summary -->
                            <div class="view1">
                                <h6 class="mb-2"><i class="bi bi-calendar3"></i> Weekly Summary</h6>
                                <div class="row g-2">
                                    @{
                                        var daysOfWeek = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
                                        var timetableList = (List<SchoolManagementSystem.Models.TimeTable>)ViewBag.TimeTableEntries;
                                    }
                                    @foreach (var day in daysOfWeek)
                                    {
                                        var dayCount = timetableList.Count(t => t.WeekDay == day);
                                        <div class="col-md-4">
                                            <div class="card border-black">
                                                <div class="card-body text-center py-2">
                                                    <strong>@day</strong><br />
                                                    <span>@dayCount classes</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                        }
                        else
                        {
                            <div class="alert alert-info text-center">
                                <i class="bi bi-info-circle fs-1"></i>
                                <p class="mb-0 mt-2">No timetable entries found. Add your first entry using the form on the left.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>


        @section Scripts {
            <script>
                function calculateDuration() {
                    var start = document.getElementById("StartTime").value;
                    var end = document.getElementById("EndTime").value;

                    if (start && end) {
                        var startTime = new Date("1970-01-01T" + start + "Z");
                        var endTime = new Date("1970-01-01T" + end + "Z");
                        var diff = (endTime - startTime) / 60000; // minutes

                        if (diff > 0) {
                            document.getElementById("DurationInMinutes").value = diff;
                        } else {
                            document.getElementById("DurationInMinutes").value = 0;
                            alert("End time must be greater than start time!");
                        }
                    }
                }

                // Reset timetable form
                function resetTimetableForm() {
                    var form = document.getElementById("timetableForm");

                    // Form reset
                    form.reset();

                    // Duration field ko clear karo
                    document.getElementById("DurationInMinutes").value = "";

                    // Validation classes remove karo
                    form.classList.remove('was-validated');

                    // All validation messages clear karo
                    var validationMessages = form.querySelectorAll('.text-danger');
                    validationMessages.forEach(function (msg) {
                        msg.innerHTML = "";
                    });
                }
            </script>
        }

    </div>




    <style>
        .profile-wrapper {
            margin: 30px; /* outside space */
            padding: 25px; /* inside space */
        }

        .profile {
            margin: 10px 30px;
            /*        padding: 15px;  inside space */
        }

        .profile1 {
            margin: 10px 30px;
            margin-left: 100px;
        }

        .text-green {
            color: #2d5f5d !important;
        }

        .btn-theme {
            background-color: #2d5f5d;
            color: white;
            border: none;
        }

            .btn-theme:hover {
                background-color: #234b49;
                color: white;
            }

        h5 ,h6 {
            color: #ff6b6b;
        }

        .view {
            margin-top: 60px;
        }

        .view1 {
            margin-top: 30px;
        }
    </style>
</div>