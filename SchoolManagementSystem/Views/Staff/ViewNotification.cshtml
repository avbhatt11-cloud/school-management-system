@model IEnumerable<SchoolManagementSystem.Models.Notification>

@{
    ViewBag.Title = "View Notification";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-4 profile mx-10">

    <h2 class="text-green mt-2 mb-2"><i class="fa fa-bell"></i>
        View Notifications</h2>
</div>
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">


    <h4 class="fw-bold mb-1 mt-1 profile1">Notifications for Staff</h4>

    <table class="table table-bordered table-hover" style="table-layout: fixed; word-wrap: break-word;">
        <thead class="table-dark">
            <tr>
                <th style="width:5%">No.</th>
                <th style="width:70%">Message</th>
                <th style="width:25%">Sent On</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int i = 1;
                foreach (var notification in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@notification.Message</td>
                        <td>@notification.CreatedDate.ToString("dd-MMM-yyyy hh:mm tt")</td>

                    </tr>
                    i++;
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">No notifications found</td>
                </tr>
            }
        </tbody>
    </table>
</div>


    <style>
        .profile-wrapper {
            margin: 30px; /* outside space */
            padding: 25px; /* inside space */
        }

        .profile {
            margin: 10px 30px;
            /*        padding: 15px;  inside space */
        }

        .profile1 {
            margin: -10px;
            
        }

        .text-green {
            color: #2d5f5d !important;
        }

        .btn-theme {
            background-color: #2d5f5d;
            color: white;
            border: none;
        }

            .btn-theme:hover {
                background-color: #234b49;
                color: white;
            }

        h4 {
            color: #ff6b6b;
        }
        .table td, .table th {
            word-break: break-word;
            white-space: normal;
            vertical-align: middle;
        }
    </style>
