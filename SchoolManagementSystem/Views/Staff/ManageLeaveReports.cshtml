@model IEnumerable<SchoolManagementSystem.Models.LeaveReport>
@{
    ViewBag.Title = "Manage Leave Reports";
}

<h2>Manage Leave Reports</h2>

@if (TempData["Success"] != null)
{<div class="alert alert-success">@TempData["Success"]</div>}
@if (TempData["Error"] != null)
{<div class="alert alert-danger">@TempData["Error"]</div>}

@using (Html.BeginForm("ManageLeaveReports", "Staff", FormMethod.Get))
{
    <div class="row mb-3">
        <div class="col-md-3">
            @Html.DropDownList("selectedClass", (SelectList)ViewBag.Classes, "All Classes", new { @class = "form-control", onchange = "this.form.submit();" })
        </div>
        <div class="col-md-3">
            @Html.DropDownList("statusFilter", (SelectList)ViewBag.StatusList, new { @class = "form-control", onchange = "this.form.submit();" })
        </div>
    </div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>Student</th>
            <th>Class</th>
            <th>Title / Reason</th>
            <th>From - To</th>
            <th>Days</th>
            <th>Status</th>
            <th>Attachment</th>
            <th>Submitted At</th>
            <th>Action</th>

        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            int i = 1;
            foreach (var r in Model)
            {
                <tr>
                    <td>@i</td>
                    <td>@(!string.IsNullOrEmpty(r.StudentName) ? r.StudentName : "N/A")</td>
                    <td>@r.ClassName</td>

                    <td>
                        <strong>@r.Title</strong><br />
                        <small>@(r.Reason?.Length > 100 ? r.Reason.Substring(0,100) + "..." : r.Reason)</small>
                    </td>
                    <td>@(r.StartDate?.ToString("yyyy-MM-dd") ?? "-") - @(r.EndDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td>@(r.Days ?? 0)</td>
                    <td>@r.Status</td>
                    <td>
                        @if (!string.IsNullOrEmpty(r.AttachmentFileName))
                        {
                            <a href="@Url.Action("DownloadLeaveAttachment","Staff", new { id = r.Id })">@r.AttachmentFileName</a>
                        }
                    </td>
                    <td>@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                    <td>
                        <a class="btn btn-sm btn-primary" href="@Url.Action("ViewLeaveReport","Staff", new { id = r.Id })">View</a>
                    </td>
                </tr>
                i++;
            }
        }
        else
        {
            <tr><td colspan="10" class="text-center">No leave reports found.</td></tr>
        }
    </tbody>
</table>
