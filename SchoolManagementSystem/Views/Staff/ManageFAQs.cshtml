@model IEnumerable<SchoolManagementSystem.Models.FAQ>
@{
    ViewBag.Title = "Manage FAQs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-4 profile mx-10">


    <h2 class="text-green mt-2 mb-2"><i class="fa fa-cogs"></i>
    Manage FAQs
</h2>
</div>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="row mt-4 g-4 border border-1 border-dark rounded-2 p-3 shadow-sm bg-white profile-wrapper">
    <table class="table table-bordered table-striped" style="table-layout: fixed; word-wrap: break-word;">
        <thead class="table-dark">
            <tr>
                <th style="width:5%">No.</th>
                <th style="width:25%">Question</th>
                <th style="width:30%">Answer</th>
                <th style="width:12%">Asked By</th>
                <th style="width:13%">Asked On</th>
                <th style="width:15%">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int i = 1;
                foreach (var faq in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@faq.Question</td>
                        <td>@faq.Answer</td>
                        <td>@faq.AskedBy</td>
                        <td>@faq.AskedOn.ToString("dd-MM-yyyy")</td>
                        <td>
                            @* Answer Button *@
                            @Html.ActionLink("Answer", "AnswerFAQ", new { id = faq.FAQId }, new { @class = "btn btn-primary btn-sm" })

                            @* Delete Button - USE ANCHOR TAG INSTEAD *@
                            <a href="@Url.Action("DeleteFAQ", "Staff", new { id = faq.FAQId })"
                               class="btn btn-danger btn-sm ms-1"
                               onclick="return confirm('Are you sure you want to delete this FAQ?\n\nQuestion: @faq.Question');">
                                <i class="fa"></i> Delete
                            </a>
                        </td>
                    </tr>
                    i++;
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center">No FAQs found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<style>
    .profile-wrapper {
        margin: 30px; /* outside space */
        padding: 25px; /* inside space */
    }

    .profile {
        margin: 10px 30px;
        /*        padding: 15px;  inside space */
    }

    .profile1 {
        margin: 10px 30px;
        margin-left: 100px;
    }

    .text-green {
        color: #2d5f5d !important;
    }

    .btn-theme {
        background-color: #2d5f5d;
        color: white;
        border: none;
    }

        .btn-theme:hover {
            background-color: #234b49;
            color: white;
        }

    .table-responsive {
        overflow-x: auto;
    }

    .badge {
        padding: 0.5em 0.75em;
        font-size: 0.875rem;
    }

    .required-star {
        color: red;
        margin-left: 3px;
        font-weight: bold;
    }

    h4 {
        color: #ff6b6b;
    }
    .table td, .table th {
        word-break: break-word;
        white-space: normal;
        vertical-align: middle;
    }
    
</style>