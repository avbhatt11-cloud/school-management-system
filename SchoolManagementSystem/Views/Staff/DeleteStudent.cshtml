@model SchoolManagementSystem.Models.Parent

@{
    ViewBag.Title = "Delete Parent";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4 text-danger">🗑 Delete Parent</h2>

<div class="alert alert-warning">
    <strong>Warning!</strong> Are you sure you want to delete this parent record?
</div>

<div class="card p-3 mb-3">
    <h5>👨 Parent: @($"{Model.ParentFirstName} {Model.ParentLastName}")</h5>
    <p><strong>Student:</strong> @($"{Model.StudentFirstName} {Model.StudentLastName}")</p>
    <p><strong>Class:</strong> @Model.ClassName</p>
    <p><strong>Contact:</strong> @Model.ContactNumber</p>
</div>

@using (Html.BeginForm("DeleteParentConfirmed", "Staff", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ParentId)

    <button type="submit" class="btn btn-danger">🗑 Yes, Delete</button>
    <a href="@Url.Action("ManageParents", "Staff")" class="btn btn-secondary">↩ Cancel</a>
}
