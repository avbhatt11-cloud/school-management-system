@model SchoolManagementSystem.Models.LoginViewModel
@{
    ViewBag.Title = "Admin Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet" />

<style>
    body {
        min-height: 100vh;
    }

    .login-container {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
    }

    .login-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        overflow: hidden;
        max-width: 1000px;
        width: 100%;
        display: flex;
        align-items: stretch;
    }

    /* ===== LEFT SIDE - TEAL GREEN ===== */
    .login-illustration {
        background-color: #2d5f5d;
        background-image: linear-gradient(135deg, #2d5f5d 0%, #1e4644 100%);
        padding: 3rem;
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        width: 40%;
    }

    .illustration-content {
        text-align: center;
    }

    .icon-wrapper {
        background: rgba(255,255,255,0.2);
        padding: 25px;
        border-radius: 50%;
        margin-bottom: 15px;
    }

        .icon-wrapper i {
            font-size: 50px;
        }

    .login-form-container {
        padding: 4rem 3rem;
        width: 60%;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .input-box {
        position: relative;
    }

    .form-control {
        height: 48px;
        border-radius: 10px;
        border: 2px solid #e0e0e0;
        background: #f8f9fa;
        padding-left: 40px;
        padding-right: 45px;
    }

        .form-control:focus {
            border-color: #2d5f5d !important;
            box-shadow: 0 0 0 0.2rem rgba(45, 95, 93, 0.25) !important;
        }

    .left-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
    }

    .right-icon {
        position: absolute;
        right: 240px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
        cursor: pointer;
        z-index: 10;
    }

    /* ===== LOGIN BUTTON - TEAL GREEN ===== */
    .btn-login {
        background-color: #2d5f5d;
        color: white;
        padding: 1rem;
        border: none;
        border-radius: 10px;
        font-size: 1.1rem;
        font-weight: 600;
        width: 100%;
        margin-top: 1rem;
    }

    .field-validation-error {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 0.25rem;
        display: block;
    }

    .alert-danger {
        background-color: #f8d7da;
        border-color: #f5c6cb;
        color: #721c24;
        padding: 1rem;
        border-radius: 10px;
        margin-bottom: 1.5rem;
    }

    @@media (max-width: 768px) {
        .login-card {
            flex-direction: column;
        }

        .login-illustration, .login-form-container {
            width: 100%;
        }

        .login-illustration {
            padding: 2rem;
        }

        .login-form-container {
            padding: 2rem;
        }
    }
</style>

<div class="login-container">
    <div class="login-card">

        <!-- LEFT -->
        <div class="login-illustration">
            <div class="illustration-content">
                <div class="icon-wrapper">
                    <i class="bi bi-person-badge"></i>
                </div>
                <h3>Admin Portal</h3>
                <p>Secure Administrator Access</p>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="login-form-container">
            <h1>Admin Login</h1>
            <p>Please enter your admin credentials</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                </div>
            }

            @using (Html.BeginForm("Login", "AdminAccount", FormMethod.Post, new { id = "loginForm" }))
            {
                @Html.AntiForgeryToken()

                <div class="form-group">
                    @Html.LabelFor(m => m.Username)
                    <div class="input-box">
                        <i class="bi bi-person left-icon"></i>
                        @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Enter admin username" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "field-validation-error" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Password)
                    <div class="input-box">
                        <i class="bi bi-lock left-icon"></i>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", id = "password", placeholder = "Enter admin password" })
                        <i class="bi bi-eye-slash right-icon" id="togglePassword"></i>
                    </div>
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-validation-error" })
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </button>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var toggle = document.getElementById("togglePassword");
            var password = document.getElementById("password");
            toggle.addEventListener("click", function () {
                if (password.type === "password") {
                    password.type = "text";
                    this.classList.remove("bi-eye-slash");
                    this.classList.add("bi-eye");
                } else {
                    password.type = "password";
                    this.classList.remove("bi-eye");
                    this.classList.add("bi-eye-slash");
                }
            });
        });
    </script>
}
